<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="configdiff-studio-azure-devops" Publisher="gatewaylabs" Version="0.1.7"/>
    <DisplayName>ConfigDiff Studio for Azure DevOps</DisplayName>
    <Description xml:space="preserve">Catch configuration drift in Azure DevOps pipelines, fail risky release gates, and compare deployments against your ConfigDiff Studio baseline.</Description>
    <GalleryFlags>Public Preview</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>configuration drift,release gates,azure devops,compliance</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#14325c"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://gatewaylabs.net/docs/quick-start"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://gatewaylabs.net/docs/support-playbook"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://gatewaylabs.net/docs/azure-devops"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://gatewaylabs.net/terms"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://gatewaylabs.net/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/Orkkoc/ConfigDiffTool"/>
    </Properties>
    <Icon>images/gatewaylabs-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="README.md" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="images/gatewaylabs-icon.png" d:Source="File" Path="images/gatewaylabs-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/gatewaylabs-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>