<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="apiverve-checks" Version="1.0.0" Publisher="apiverve"/>
    <DisplayName>APIVerve Checks — SSL, Domain, DNS &amp; Email Gates</DisplayName>
    <Description xml:space="preserve">Pipeline gates for SSL expiry, domain expiration, DNS, and email auth — plus call any of 368+ APIVerve APIs from your pipeline.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>ssl,certificate,expiry,domain,dns,spf,dkim,dmarc,monitoring,gate,api,apiverve</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://apiverve.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://docs.apiverve.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://apiverve.com/contact"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://apiverve.com/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/apiverve/azure-devops-checks"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="images/hero.png" d:Source="File" Path="images/hero.png" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="images/pipeline-log.png" d:Source="File" Path="images/pipeline-log.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>