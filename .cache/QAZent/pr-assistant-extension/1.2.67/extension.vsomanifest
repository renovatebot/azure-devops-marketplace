{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "ai-context-settings-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "name": "QAZent PR Assistant",
                "order": 100,
                "uri": "dist/settings.html",
                "backendUrl": "api.qazent.com"
            }
        },
        {
            "id": "pr-assistant-pull-request-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-code-web.pull-request-hub"
            ],
            "properties": {
                "name": "PR Assistant",
                "order": 100,
                "uri": "dist/hub.html",
                "backendUrl": "api.qazent.com"
            }
        }
    ],
    "scopes": [
        "vso.code_write",
        "vso.work_write",
        "vso.notification_write",
        "vso.hooks_interact",
        "vso.threads_full"
    ],
    "contributionTypes": []
}