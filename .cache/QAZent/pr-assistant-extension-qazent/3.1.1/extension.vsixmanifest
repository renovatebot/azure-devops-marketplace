<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="pr-assistant-extension-qazent" Version="3.1.1" Publisher="QAZent"/>
    <DisplayName>PR Assistant</DisplayName>
    <GalleryFlags>Public Paid Preview</GalleryFlags>
    <Description xml:space="preserve">AI-powered PR test case generation assistant</Description>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="14"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#1f2937"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://www.qazent.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://www.qazent.com/support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://www.qazent.com/license"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.qazent.com/privacy"/>
    </Properties>
    <Tags>__BYOLENFORCED,pull-request,testing,ai,test,utility,automatic,agile</Tags>
    <Categories>Azure Repos,Azure Boards</Categories>
    <License>license-terms.md</License>
    <Icon>128x128.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="public/custom-context-dropdown.png" d:Source="File" Path="public/custom-context-dropdown.png" Addressable="true"/>
    <Asset Type="public/custom-context.png" d:Source="File" Path="public/custom-context.png" Addressable="true"/>
    <Asset Type="public/generate-testcase.png" d:Source="File" Path="public/generate-testcase.png" Addressable="true"/>
    <Asset Type="public/generated-test-case.png" d:Source="File" Path="public/generated-test-case.png" Addressable="true"/>
    <Asset Type="public/hero-preview.png" d:Source="File" Path="public/hero-preview.png" Addressable="true"/>
    <Asset Type="public/linking-pr.png" d:Source="File" Path="public/linking-pr.png" Addressable="true"/>
    <Asset Type="public/pr-assistant-tab.png" d:Source="File" Path="public/pr-assistant-tab.png" Addressable="true"/>
    <Asset Type="public/QAZent_Showcase1.gif" d:Source="File" Path="public/QAZent_Showcase1.gif" Addressable="true"/>
    <Asset Type="public/step-1.png" d:Source="File" Path="public/step-1.png" Addressable="true"/>
    <Asset Type="public/step-3.png" d:Source="File" Path="public/step-3.png" Addressable="true"/>
    <Asset Type="public/where-to-find-settings.png" d:Source="File" Path="public/where-to-find-settings.png" Addressable="true"/>
    <Asset Type="public/work-item-created.png" d:Source="File" Path="public/work-item-created.png" Addressable="true"/>
    <Asset Type="hub.html" d:Source="File" Path="hub.html" Addressable="true"/>
    <Asset Type="settings.html" d:Source="File" Path="settings.html" Addressable="true"/>
    <Asset Type="hub.js" d:Source="File" Path="hub.js" Addressable="true"/>
    <Asset Type="settings.js" d:Source="File" Path="settings.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Pricing" d:Source="File" Path="pricing.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="license-terms.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Privacy" d:Source="File" Path="privacy-policy.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="128x128.png" Addressable="true"/>
