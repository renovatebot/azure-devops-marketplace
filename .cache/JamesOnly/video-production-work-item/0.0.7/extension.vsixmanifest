<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="video-production-work-item" Publisher="JamesOnly" Version="0.0.7"/>
    <DisplayName>Video production request (work item)</DisplayName>
    <Description xml:space="preserve">Compose a video production request from an Azure DevOps work item and send it by email via a Microsoft Graph-backed API (directory search and mail).</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="out/static/video-request-page.css" d:Source="File" Path="out/static/video-request-page.css" Addressable="true"/>
    <Asset Type="out/static/video-request-page.html" d:Source="File" Path="out/static/video-request-page.html" Addressable="true"/>
    <Asset Type="out/static/videoRequestPage.js" d:Source="File" Path="out/static/videoRequestPage.js" Addressable="true"/>
    <Asset Type="out/static/videoRequestPage.js.LICENSE.txt" d:Source="File" Path="out/static/videoRequestPage.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>