{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "ai-pr-review-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "AIPRReviewTask"
            }
        },
        {
            "id": "azure-openai-pr-review-endpoint",
            "description": "Azure OpenAI endpoint (endpoint URL + API key) used by the AI PR Review task.",
            "type": "ms.vss-endpoint.service-endpoint-type",
            "targets": [
                "ms.vss-endpoint.endpoint-types"
            ],
            "properties": {
                "name": "AzureOpenAIPRReview",
                "displayName": "Azure OpenAI PR Review",
                "url": {
                    "displayName": "Endpoint URL",
                    "helpText": "Azure OpenAI resource endpoint, e.g. https://your-resource.cognitiveservices.azure.com (NOT the Foundry services.ai.azure.com form). A full request URL is also accepted and normalized to scheme+host.",
                    "value": "https://your-resource.cognitiveservices.azure.com"
                },
                "authenticationSchemes": [
                    {
                        "type": "ms.vss-endpoint.endpoint-auth-scheme-token",
                        "properties": {
                            "displayName": "API Key"
                        }
                    }
                ],
                "helpMarkDown": "Create one connection per project holding your Azure OpenAI endpoint URL and API key. The AI PR Review task reads the endpoint URL and key from this connection."
            }
        }
    ],
    "scopes": [],
    "contributionTypes": []
}