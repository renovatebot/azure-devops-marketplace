  <Metadata>
    <Identity Language="en-US" Id="ado-project-scaffolder" Publisher="namoshek" Version="0.17.0"/>
    <DisplayName>Project Scaffolder</DisplayName>
    <Description xml:space="preserve">Scaffold repositories and pipelines across your Azure DevOps projects from your own templates — guided, parameterized, and non-destructive.</Description>
    <GalleryFlags>Public Preview</GalleryFlags>
    <Categories>Azure Repos,Azure Pipelines</Categories>
    <Tags>scaffolding,templates,projects,repos,pipelines,automation,generator,boilerplate,yaml,devops</Tags>
