{
    "manifestVersion": 1,
    "scopes": [
        "vso.work",
        "vso.code",
        "vso.build_execute",
        "vso.extension.data_write"
    ],
    "contributions": [
        {
            "id": "branchdeploy-action",
            "type": "ms.vss-web.action",
            "description": "Deploy the branch linked to this work item to the test environment.",
            "targets": [
                "ms.vss-work-web.work-item-toolbar-menu"
            ],
            "properties": {
                "text": "Deploy linked branch to test",
                "title": "Deploy the branch linked to this ticket",
                "toolbarText": "Deploy linked branch to test",
                "icon": "dist/icons/branchdeploy.png",
                "uri": "dist/deploy-action.html",
                "registeredObjectId": "branchdeploy-action-handler"
            }
        },
        {
            "id": "branchdeploy-project-settings",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "name": "BranchDeploy",
                "order": 90,
                "icon": "dist/icons/branchdeploy.png",
                "uri": "dist/settings.html"
            }
        }
    ],
    "contributionTypes": []
}