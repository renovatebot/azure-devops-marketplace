    <DisplayName> Work Item Sheets</DisplayName>
    <Description xml:space="preserve">Edit Azure DevOps work items like a spreadsheet. View, bulk edit, and manage hundreds of work items instantly in a fast, grid-based interface built for real productivity.</Description>
    <GalleryFlags>Paid</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Properties>
