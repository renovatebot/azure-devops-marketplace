  <Metadata>
    <Identity Language="en-US" Id="rixter-risk-manager" Publisher="rixterab" Version="1.0.5"/>
    <DisplayName>Risk Manager</DisplayName>
    <Description xml:space="preserve">The app lets you visualize risks by displaying Azure Devops workitems in a Risk Matrix based on their probability and impact, making it easy to see and assess risk levels at dashboards.</Description>
    <GalleryFlags>Paid</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="30"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://rixter.atlassian.net/servicedesk/customer/portal/2"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://license.rixter.net/privacy/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://license.rixter.net/eula/"/>
    </Properties>
    <Tags>__BYOLENFORCED</Tags>
    <Icon>nextjs/out/images/icon.png</Icon>
    <License>license.md</License>
  </Metadata>
