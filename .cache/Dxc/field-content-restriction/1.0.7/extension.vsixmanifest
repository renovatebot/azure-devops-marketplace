<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="field-content-restriction" Publisher="Dxc" Version="1.0.7"/>
    <GalleryFlags>Public</GalleryFlags>
    <DisplayName>Work Item Field Content Restriction</DisplayName>
    <Description xml:space="preserve">Restrict and validate the content of work item fields using configurable rules (regex patterns, blocked words, max length, allowed values).</Description>
    <Categories>Azure Boards</Categories>
    <Icon>img/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/field-validator.html" d:Source="File" Path="dist/field-validator.html" Addressable="true"/>
    <Asset Type="dist/field-validator.js" d:Source="File" Path="dist/field-validator.js" Addressable="true"/>
    <Asset Type="dist/settings.html" d:Source="File" Path="dist/settings.html" Addressable="true"/>
    <Asset Type="dist/settings.js" d:Source="File" Path="dist/settings.js" Addressable="true"/>
    <Asset Type="static/css/settings.css" d:Source="File" Path="static/css/settings.css" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>