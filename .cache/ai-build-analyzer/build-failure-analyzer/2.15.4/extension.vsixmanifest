<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="build-failure-analyzer" Publisher="ai-build-analyzer" Version="2.15.4"/>
    <DisplayName>Azure DevOps Build AI Analyzer</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Analyzes failed pipeline runs with your own OpenAI-compatible LLM (local or hosted): a pipeline task produces the analysis and a build results tab displays it.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>Azure Pipelines,AI,LLM,Ollama,Build,CI/CD,DevOps</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/jafarimohammad/azdevops-build-ai-analyzer"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/jafarimohammad/azdevops-build-ai-analyzer/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/jafarimohammad/azdevops-build-ai-analyzer/blob/main/LICENSE"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/jafarimohammad/azdevops-build-ai-analyzer/blob/main/PRIVACY.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/jafarimohammad/azdevops-build-ai-analyzer"/>
    </Properties>
    <Icon>images/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="content/ai-tab.html" d:Source="File" Path="content/ai-tab.html" Addressable="true"/>
    <Asset Type="content/ai-tab.js" d:Source="File" Path="content/ai-tab.js" Addressable="true"/>
    <Asset Type="content/styles.css" d:Source="File" Path="content/styles.css" Addressable="true"/>
    <Asset Type="content/lib/SDK.min.js" d:Source="File" Path="content/lib/SDK.min.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>