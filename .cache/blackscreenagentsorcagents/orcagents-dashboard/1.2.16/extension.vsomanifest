{
    "manifestVersion": 1,
    "scopes": [
        "vso.work_write",
        "vso.dashboards",
        "vso.code"
    ],
    "contributions": [
        {
            "id": "orcagents-widget-timeline",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Workflow execution timeline",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Agent Timeline",
                "description": "Shows workflow execution timeline with zoom/pan",
                "catalogIconUrl": "images/icons/timeline.png",
                "previewImageUrl": "images/icons/timeline.png",
                "uri": "html/widget-timeline.html",
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-widget-flow-dag",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Flow dependency graph",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Flow DAG",
                "description": "Shows flow dependency graph with node states",
                "catalogIconUrl": "images/icons/flow-dag.png",
                "previewImageUrl": "images/icons/flow-dag.png",
                "uri": "html/widget-flow-dag.html",
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-pr-tab",
            "type": "ms.vss-code-web.pr-tabs-page",
            "description": "Agent review activity for this pull request",
            "targets": [
                "ms.vss-code-web.pr-tabs"
            ],
            "properties": {
                "name": "Agent",
                "uri": "html/pr-tab.html"
            }
        },
        {
            "id": "orcagents-work-item-tab",
            "type": "ms.vss-work-web.work-item-form-page",
            "description": "Agent session status for this work item",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Agent",
                "uri": "html/work-item-tab.html",
                "height": 600
            }
        },
        {
            "id": "orcagents-workflows-hub",
            "type": "ms.vss-web.hub",
            "description": "Define, trigger, and monitor MAF agent workflows",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Workflows",
                "order": 50,
                "uri": "html/workflows-hub.html",
                "iconName": "BranchFork2"
            }
        },
        {
            "id": "orcagents-approvals-hub",
            "type": "ms.vss-web.hub",
            "description": "HITL pending approvals — approve or reject agent-proposed changes",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Approvals",
                "order": 51,
                "uri": "html/approvals-hub.html",
                "iconName": "CheckMark"
            }
        },
        {
            "id": "orcagents-activity-hub",
            "type": "ms.vss-web.hub",
            "description": "Real-time agent activity stream and session timeline",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Activity",
                "order": 52,
                "uri": "html/activity-hub.html",
                "iconName": "History"
            }
        },
        {
            "id": "orcagents-team-hub",
            "type": "ms.vss-web.hub",
            "description": "Agent team composer and GPU cluster status",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Teams",
                "order": 53,
                "uri": "html/team-hub.html",
                "iconName": "People"
            }
        },
        {
            "id": "orcagents-repos-hub",
            "type": "ms.vss-web.hub",
            "description": "Map repository short names to ADO clone URLs",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Repositories",
                "order": 54,
                "uri": "html/repos-hub.html",
                "iconName": "GitLogo"
            }
        },
        {
            "id": "orcagents-search-hub",
            "type": "ms.vss-web.hub",
            "description": "Semantic codebase search via pgvector embeddings",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Agent Search",
                "order": 55,
                "uri": "html/search-hub.html",
                "iconName": "Search"
            }
        },
        {
            "id": "orcagents-settings-hub",
            "type": "ms.vss-web.hub",
            "description": "Configure DevOrcs Platform.Api connection settings",
            "targets": [
                "ms.vss-web.collection-admin-hub-group"
            ],
            "properties": {
                "name": "DevOrcs Settings",
                "order": 99,
                "uri": "html/settings-hub.html"
            }
        },
        {
            "id": "orcagents-widget-approvals",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Pending HITL approvals count",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Agent Approvals",
                "description": "Shows the count of pending HITL approvals",
                "catalogIconUrl": "images/icons/approvals.png",
                "previewImageUrl": "images/icons/approvals.png",
                "uri": "html/widget-approvals.html",
                "supportedSizes": [
                    {
                        "rowSpan": 1,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-widget-sessions",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Active agent sessions count",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Agent Sessions",
                "description": "Shows the count of currently active agent sessions",
                "catalogIconUrl": "images/icons/activity.png",
                "previewImageUrl": "images/icons/activity.png",
                "uri": "html/widget-sessions.html",
                "supportedSizes": [
                    {
                        "rowSpan": 1,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-widget-gpu",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Cluster GPU utilization",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "GPU Load",
                "description": "Shows average GPU utilization across the on-prem cluster",
                "catalogIconUrl": "images/icons/gpu.png",
                "previewImageUrl": "images/icons/gpu.png",
                "uri": "html/widget-gpu.html",
                "supportedSizes": [
                    {
                        "rowSpan": 1,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-widget-sprint-health",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Sprint health metrics by persona",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Sprint Health",
                "description": "Shows completed, failed, and pending sessions by persona for the current sprint",
                "catalogIconUrl": "images/icons/sprint-health.png",
                "previewImageUrl": "images/icons/sprint-health.png",
                "uri": "html/widget-sprint-health.html",
                "supportedSizes": [
                    {
                        "rowSpan": 1,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-widget-approval-sla",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Approval SLA compliance dashboard",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Approval SLA",
                "description": "Shows approval pending time with SLA compliance bands",
                "catalogIconUrl": "images/icons/approval-sla.png",
                "previewImageUrl": "images/icons/approval-sla.png",
                "uri": "html/widget-approval-sla.html",
                "supportedSizes": [
                    {
                        "rowSpan": 1,
                        "columnSpan": 2
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "orcagents-pipeline-gate",
            "type": "ms.vss-distributed-task.gate",
            "description": "Blocks a pipeline stage until the platform's HITL approval gate is resolved.",
            "targets": [
                "ms.vss-distributed-task.gate-task"
            ],
            "properties": {
                "name": "DevOrcs Approval Gate",
                "description": "Blocks a pipeline stage until the platform's HITL approval gate is resolved.",
                "category": "Utility",
                "visibility": [
                    "Build",
                    "Release"
                ],
                "runsOn": [
                    "Gate"
                ],
                "execution": {
                    "Node20_1": {
                        "target": "dist/gate.js"
                    }
                },
                "inputs": [
                    {
                        "name": "apiUrl",
                        "type": "string",
                        "label": "Platform API URL",
                        "required": true,
                        "defaultValue": ""
                    },
                    {
                        "name": "apiKey",
                        "type": "string",
                        "label": "API Key",
                        "required": true,
                        "defaultValue": ""
                    },
                    {
                        "name": "sessionIdVariable",
                        "type": "string",
                        "label": "Session ID Variable",
                        "required": false,
                        "defaultValue": "$(AgentSessionId)"
                    }
                ]
            }
        }
    ],
    "contributionTypes": []
}