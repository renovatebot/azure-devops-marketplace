      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://rothausendevelopment.visualstudio.com/ADOTimeTracker/_git/ADOTimeTracker"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
