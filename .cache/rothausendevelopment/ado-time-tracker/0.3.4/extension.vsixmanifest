  <Metadata>
    <Identity Language="en-US" Id="ado-time-tracker" Publisher="rothausendevelopment" Version="0.3.4"/>
    <DisplayName>Time Tracker</DisplayName>
    <Description xml:space="preserve">Log time against work items and report on logged time.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>time-tracking,timesheet,reporting,hours,work-items,billing</Tags>
    <GalleryFlags>Public</GalleryFlags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#222631"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
