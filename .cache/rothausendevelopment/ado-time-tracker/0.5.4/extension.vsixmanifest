  <Metadata>
    <Identity Language="en-US" Id="ado-time-tracker" Publisher="rothausendevelopment" Version="0.5.4"/>
    <DisplayName>Time Tracker</DisplayName>
    <Description xml:space="preserve">Log time against work items, report on logged time, and back up entries to JSON.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>time-tracking,timesheet,reporting,hours,work-items,billing,backup,export,import</Tags>
    <GalleryFlags>Public</GalleryFlags>
    <Properties>
