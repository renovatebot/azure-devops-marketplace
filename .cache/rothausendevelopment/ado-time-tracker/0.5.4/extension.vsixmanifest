      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="mailto:info@rothausendevelopment.com"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
