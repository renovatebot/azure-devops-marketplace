<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="taudit-azure-pipelines" Publisher="algol" Version="0.1.2"/>
    <DisplayName>taudit</DisplayName>
    <Description xml:space="preserve">Run taudit verify, scan, and graph in Azure Pipelines through a typed pipeline task.</Description>
    <GalleryFlags/>
    <Categories>Azure Pipelines</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#111827"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/0ryant/taudit/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://github.com/0ryant/taudit/blob/main/integrations/azure-devops-extension/README.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/0ryant/taudit/blob/main/LICENSE"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/0ryant/taudit"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>