<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="albuild-devops" Version="2.0.26531" Publisher="365businessdevelopment"/>
    <DisplayName>ALbuild for Azure DevOps</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Granular Azure DevOps pipeline tasks for Microsoft Dynamics 365 Business Central AL development, built on the businessdev.ALbuild PowerShell module.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>Business Central,AL,Dynamics 365,Docker,AppSource</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://365businessdev.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://docs.365businessdev.com/albuild/get-started"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://docs.365businessdev.com/albuild/index"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="http://servicedesk.365businessdev.com/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="http://servicedesk.365businessdev.com/"/>
    </Properties>
    <Icon>res/icon128x128.png</Icon>
    <License>eula.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="res/icon128x128.png" d:Source="File" Path="res/icon128x128.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="res/icon128x128.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="eula.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Privacypolicy" d:Source="File" Path="privacy.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>