<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="percentage-tile-widget" Version="1.0.7" Publisher="JosipGracak"/>
    <DisplayName>Percentage Tile Widget</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">A dashboard widget tile that shows the count of work items from a query and a percentage relative to a second query.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>dashboard,widget,percentage,queries,work items</Tags>
    <Icon>img/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/configuration.html" d:Source="File" Path="dist/configuration.html" Addressable="true"/>
    <Asset Type="dist/configuration.js" d:Source="File" Path="dist/configuration.js" Addressable="true"/>
    <Asset Type="dist/widget.html" d:Source="File" Path="dist/widget.html" Addressable="true"/>
    <Asset Type="dist/widget.js" d:Source="File" Path="dist/widget.js" Addressable="true"/>
    <Asset Type="img/logo.png" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>