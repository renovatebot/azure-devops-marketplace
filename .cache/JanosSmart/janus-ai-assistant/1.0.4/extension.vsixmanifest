  <Metadata>
    <Identity Language="en-US" Id="janus-ai-assistant" Version="1.0.4" Publisher="janossmart"/>
    <DisplayName>Janus AI Assistant ✨</DisplayName>
    <Description xml:space="preserve">Improve work items, generate children &amp; test cases, and convert BRDs into full backlogs — powered by 8 AI providers, with PII protection and no vendor lock-in.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>AI,Work Items,Copilot,Backlog,GPT,OpenAI,Azure OpenAI,Test Cases,User Stories,Sprint Planning,BRD,Productivity,DevOps</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://marketplace.visualstudio.com/items?itemName=janossmart.janus-ai-assistant&amp;ssr=false#qna"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Website" Value="https://janosmart.com/"/>
    </Properties>
    <GalleryFlags>Public</GalleryFlags>
    <Icon>public/janus.png</Icon>
  </Metadata>
