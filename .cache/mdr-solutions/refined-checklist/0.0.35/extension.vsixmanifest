<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="refined-checklist" Version="0.0.35" Publisher="mdr-solutions"/>
    <DisplayName>Refined Checklist</DisplayName>
    <Description xml:space="preserve">Configurable checklist for work items</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/MDRSolutions/Checklist#installation"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://github.com/MDRSolutions/Checklist"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/MDRSolutions/Checklist/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/MDRSolutions/Checklist/blob/main/LICENSE"/>
    </Properties>
    <Icon>static/logo.png</Icon>
    <License>dist/LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/checklist/checklist.js" d:Source="File" Path="dist/checklist/checklist.js" Addressable="true"/>
    <Asset Type="dist/checklist/checklist.js.LICENSE.txt" d:Source="File" Path="dist/checklist/checklist.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/checklist/index.html" d:Source="File" Path="dist/checklist/index.html" Addressable="true"/>
    <Asset Type="dist/settings/index.html" d:Source="File" Path="dist/settings/index.html" Addressable="true"/>
    <Asset Type="dist/settings/settings.js" d:Source="File" Path="dist/settings/settings.js" Addressable="true"/>
    <Asset Type="dist/settings/settings.js.LICENSE.txt" d:Source="File" Path="dist/settings/settings.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/logo.png" d:Source="File" Path="static/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="dist/overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="dist/LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>