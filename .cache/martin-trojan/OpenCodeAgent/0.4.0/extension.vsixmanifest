<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="OpenCodeAgent" Version="0.4.0" Publisher="martin-trojan"/>
    <DisplayName>OpenCodeAgent</DisplayName>
    <Description xml:space="preserve">Azure DevOps pipeline task that responds to PR comments containing '/oc' or '/opencode' by executing the OpenCode AI agent to analyze code, make changes, and commit back to pull requests</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>build,release,azure-pipelines,tasks,ai,code-review,opencode</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/trojanmartin/opencode-azdo-extension"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/trojanmartin/opencode-azdo-extension/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/trojanmartin/opencode-azdo-extension"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Opencode" Value="https://opencode.ai/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/trojanmartin/opencode-azdo-extension"/>
    </Properties>
    <GalleryFlags/>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>