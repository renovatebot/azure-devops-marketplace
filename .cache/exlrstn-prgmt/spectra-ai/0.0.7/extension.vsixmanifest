<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Version="0.0.7" Publisher="exlrstn-prgmt" Id="spectra-ai"/>
    <DisplayName>Spectra</DisplayName>
    <Description xml:space="preserve">Spectra uses Claude AI to illuminate your work items — turning a 2–3 sentence Requirement or Bug into a detailed description and follow-up tasks in seconds.</Description>
    <Categories>Azure Boards</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Icon>img/enricher-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/enrich-form/enrich-form.html" d:Source="File" Path="dist/enrich-form/enrich-form.html" Addressable="true"/>
    <Asset Type="dist/enrich-form/enrich-form.js" d:Source="File" Path="dist/enrich-form/enrich-form.js" Addressable="true"/>
    <Asset Type="dist/enrich-workitem/enrich-workitem.html" d:Source="File" Path="dist/enrich-workitem/enrich-workitem.html" Addressable="true"/>
    <Asset Type="dist/enrich-workitem/enrich-workitem.js" d:Source="File" Path="dist/enrich-workitem/enrich-workitem.js" Addressable="true"/>
    <Asset Type="dist/refine-dialog/refine-dialog.html" d:Source="File" Path="dist/refine-dialog/refine-dialog.html" Addressable="true"/>
    <Asset Type="dist/refine-dialog/refine-dialog.js" d:Source="File" Path="dist/refine-dialog/refine-dialog.js" Addressable="true"/>
    <Asset Type="dist/refine-group/refine-group.html" d:Source="File" Path="dist/refine-group/refine-group.html" Addressable="true"/>
    <Asset Type="dist/refine-group/refine-group.js" d:Source="File" Path="dist/refine-group/refine-group.js" Addressable="true"/>
    <Asset Type="dist/settings-hub/settings-hub.html" d:Source="File" Path="dist/settings-hub/settings-hub.html" Addressable="true"/>
    <Asset Type="dist/settings-hub/settings-hub.js" d:Source="File" Path="dist/settings-hub/settings-hub.js" Addressable="true"/>
    <Asset Type="img/enricher-icon.png" d:Source="File" Path="img/enricher-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/enricher-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>