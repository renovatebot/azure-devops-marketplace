<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="azure-repos-pr-reviewer" Publisher="InnovaAppsGH" Version="0.1.0"/>
    <DisplayName>Azure Repos PR Reviewer</DisplayName>
    <Description xml:space="preserve">AI-assisted pull request reviewer for Azure Repos</Description>
    <Categories>Azure Repos</Categories>
    <Icon>static/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/github-callback/github-callback.html" d:Source="File" Path="dist/github-callback/github-callback.html" Addressable="true"/>
    <Asset Type="dist/github-callback/github-callback.js" d:Source="File" Path="dist/github-callback/github-callback.js" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.html" d:Source="File" Path="dist/pr-review-action/pr-review-action.html" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.js" d:Source="File" Path="dist/pr-review-action/pr-review-action.js" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.js.LICENSE.txt" d:Source="File" Path="dist/pr-review-action/pr-review-action.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/.gitkeep" d:Source="File" Path="static/.gitkeep" Addressable="true"/>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>