<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="azure-repos-pr-reviewer" Publisher="InnovaAppsGH" Version="1.0.1"/>
    <DisplayName>GitHub Copilot Code Reviewer</DisplayName>
    <Description xml:space="preserve">AI pull request reviews for Azure Repos with GitHub Copilot, inline findings, and draft approval</Description>
    <Categories>Azure Repos</Categories>
    <GalleryFlags>Paid Preview</GalleryFlags>
    <Tags>ai,pr,code-review,pull-request,copilot,agent,llm,agentic,github,github-copilot,security,inline-comments,suggestions,azure-repos,draft-review,oauth</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://site.innovaapps.ai/support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://site.innovaapps.ai/policies"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/InnovaAppsGH/azure-repos-pr-reviewer"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>static/icon.png</Icon>
    <License>eula.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/github-callback/github-callback.html" d:Source="File" Path="dist/github-callback/github-callback.html" Addressable="true"/>
    <Asset Type="dist/github-callback/github-callback.js" d:Source="File" Path="dist/github-callback/github-callback.js" Addressable="true"/>
    <Asset Type="dist/github-login-panel/github-login-panel.html" d:Source="File" Path="dist/github-login-panel/github-login-panel.html" Addressable="true"/>
    <Asset Type="dist/github-login-panel/github-login-panel.js" d:Source="File" Path="dist/github-login-panel/github-login-panel.js" Addressable="true"/>
    <Asset Type="dist/github-login-panel/github-login-panel.js.LICENSE.txt" d:Source="File" Path="dist/github-login-panel/github-login-panel.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.html" d:Source="File" Path="dist/pr-review-action/pr-review-action.html" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.js" d:Source="File" Path="dist/pr-review-action/pr-review-action.js" Addressable="true"/>
    <Asset Type="dist/pr-review-action/pr-review-action.js.LICENSE.txt" d:Source="File" Path="dist/pr-review-action/pr-review-action.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/review-results-panel/review-results-panel.html" d:Source="File" Path="dist/review-results-panel/review-results-panel.html" Addressable="true"/>
    <Asset Type="dist/review-results-panel/review-results-panel.js" d:Source="File" Path="dist/review-results-panel/review-results-panel.js" Addressable="true"/>
    <Asset Type="dist/review-results-panel/review-results-panel.js.LICENSE.txt" d:Source="File" Path="dist/review-results-panel/review-results-panel.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/.gitkeep" d:Source="File" Path="static/.gitkeep" Addressable="true"/>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="eula.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>