<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="bulk-task-creator-for-stories" Version="1.0.34" Publisher="DineshRajendran"/>
    <DisplayName>Child Task Creator for User Stories</DisplayName>
    <Description xml:space="preserve">Create multiple child tasks directly from a User Story with automatic area and iteration inheritance, user assignment, and time estimates.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>work items,tasks,user stories,bulk operations,DevOps</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/devops-extensions/task-creator"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#3087d1"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>src/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="src/icon.png" d:Source="File" Path="src/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="src/icon.png" Addressable="true"/>
    <Asset Type="src/task-creator-action.html" d:Source="File" Path="src/task-creator-action.html" Addressable="true"/>
    <Asset Type="src/task-creator-dialog.html" d:Source="File" Path="src/task-creator-dialog.html" Addressable="true"/>
    <Asset Type="src/task-creator-toolbar.html" d:Source="File" Path="src/task-creator-toolbar.html" Addressable="true"/>
    <Asset Type="src/VSS.SDK.min.js" d:Source="File" Path="src/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>