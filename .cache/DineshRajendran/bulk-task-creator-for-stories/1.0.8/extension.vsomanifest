{
    "manifestVersion": 1,
    "baseUri": "src",
    "repository": {
        "type": "git",
        "uri": "https://github.com/devops-extensions/task-creator"
    },
    "contributions": [
        {
            "id": "create-tasks-script",
            "type": "ms.vss-web.script",
            "properties": {
                "uri": "src/create-tasks-action.js"
            }
        },
        {
            "id": "create-tasks-menu",
            "type": "ms.vss-web.work-item-form-menu",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "text": "Create Tasks",
                "title": "Create bulk tasks for this user story",
                "icon": "src/icon.png",
                "action": "CreateTasksAction"
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write"
    ],
    "contributionTypes": []
}