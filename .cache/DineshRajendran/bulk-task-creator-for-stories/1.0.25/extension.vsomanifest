{
    "manifestVersion": 1,
    "repository": {
        "type": "git",
        "uri": "https://github.com/devops-extensions/task-creator"
    },
    "contributions": [
        {
            "id": "task-creator-group",
            "type": "ms.vss-work-web.work-item-form-group",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Create Child Tasks",
                "label": "Create Child Tasks",
                "uri": "src/task-creator-group.html",
                "height": 50
            }
        },
        {
            "id": "task-creator-dialog",
            "type": "ms.vss-web.control",
            "description": "Dialog content for creating child tasks on a User Story",
            "properties": {
                "uri": "src/task-creator-dialog.html"
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write"
    ],
    "contributionTypes": []
}