<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="update-nuspec" Publisher="peshkov" Version="2.0.68"/>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/denis-peshkov/update-nuspec-action"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#f4f7fb"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://github.com/denis-peshkov/update-nuspec-action"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/denis-peshkov/update-nuspec-action/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/denis-peshkov/update-nuspec-action"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/denis-peshkov/update-nuspec-action/appendices/privacy-policy/"/>
    </Properties>
    <GalleryFlags>Public</GalleryFlags>
    <DisplayName>Update *.nuspec</DisplayName>
    <Description xml:space="preserve">CLI to sync NuGet dependencies in *.nuspec with PackageReference versions from matching *.csproj files.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>cli,nuget,nuspec,dotnet,csproj,azure-pipelines,ci</Tags>
    <Icon>marketplace/extension-icon.png</Icon>
    <License>marketplace/license.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="marketplace/images/example-boilerplate-url-normalizer.png" d:Source="File" Path="marketplace/images/example-boilerplate-url-normalizer.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.1" d:Source="File" Path="marketplace/images/example-boilerplate-url-normalizer.png" Addressable="true"/>
    <Asset Type="marketplace/images/example-package-json.png" d:Source="File" Path="marketplace/images/example-package-json.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.2" d:Source="File" Path="marketplace/images/example-package-json.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="marketplace/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="marketplace/overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="marketplace/license.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>