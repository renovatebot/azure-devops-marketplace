            "properties": {
                "name": "Release Burndown Burnup Chart",
                "description": "Displays burndown or burnup chart for work items defined by a release-scope query. Use this widget to track overall progress or create cross-team burndown charts. #stonikbyte #great gadgets",
                "uri": "azure/extensions/release-chart-gadget.shtm",
                "isNameConfigurable": false,
