{
    "manifestVersion": 1,
    "scopes": [
        "vso.dashboards",
        "vso.dashboards_manage",
        "vso.settings",
        "vso.project",
        "vso.work",
        "vso.profile",
        "vso.graph",
        "vso.identity",
        "vso.memberentitlementmanagement"
    ],
    "contributions": [
        {
            "id": "id-hub-great-gadgets-configuration",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.collection-admin-hub-group"
            ],
            "properties": {
                "name": "Great Gadgets",
                "order": 100,
                "icon": "gadgets/imagesgadgets/images/logoConfiguration.png",
                "uri": "azure/extensions/great-gadgets-configuration.shtm"
            }
        },
        {
            "id": "id-widget-advanced-filter-based-formula-gadget",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Advanced Formula Widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Advanced Formula Widget",
                "description": "Displays the results of up to 9 formulas applied to numeric fields of work items from up to 9 queries. Use this widget to show key project numbers, metrics, or KPIs as percentages, ratios, averages, totals, or sums. #stonikbyte #great gadgets",
                "uri": "azure/extensions/advanced-filter-based-formula.shtm",
                "isNameConfigurable": false,
                "catalogIconUrl": "/gadgets/images/advanced-filter-based-formula-azure.png",
                "previewImageUrl": "/gadgets/images/advanced-filter-based-formula-azure.png",
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 3
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "id-widget-advanced-filter-based-formula-gadget-config-internal",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "uri": "azure/extensions/advanced-filter-based-formula.shtm?config=true&internal=true"
            }
        },
        {
            "id": "id-widget-advanced-filter-based-formula-gadget-config",
            "type": "ms.vss-web.external-content",
            "targets": [],
            "properties": {
                "uri": "azure/extensions/advanced-filter-based-formula.shtm?config=true"
            }
        },
        {
            "id": "id-widget-cycle-time-control-chart-gadget",
            "type": "ms.vss-dashboards-web.widget",
            "description": "Control Chart Widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog",
                ".id-widget-cycle-time-control-chart-gadget-config-internal"
            ],
            "properties": {
                "name": "Control Chart Widget",
                "description": "A scatter plot showing work items by cycle time, lead time, or time between two workflow statuses. Use this widget to view average resolution times and identify work items that exceeded the SLA. #stonikbyte #great gadgets",
                "uri": "azure/extensions/cycle-time-control-chart-gadget.shtm",
                "isNameConfigurable": false,
                "catalogIconUrl": "/gadgets/images/cycle-time-control-chart-gadget-azure.png",
                "previewImageUrl": "/gadgets/images/cycle-time-control-chart-gadget-azure.png",
                "supportedSizes": [
                    {
                        "rowSpan": 3,
                        "columnSpan": 4
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "id-widget-cycle-time-control-chart-gadget-config-internal",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "uri": "azure/extensions/cycle-time-control-chart-gadget.shtm?config=true&internal=true"
            }
        },
        {
            "id": "id-widget-cycle-time-control-chart-gadget-config",
            "type": "ms.vss-web.external-content",
            "targets": [],
            "properties": {
                "uri": "azure/extensions/cycle-time-control-chart-gadget.shtm?config=true"
            }
        },
        {
