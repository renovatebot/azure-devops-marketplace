            "description": "Issue Filter Formula Gadget description",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog"
            ],
            "properties": {
                "name": "Issue Filter Formula Gadget",
                "description": "Displays the result of a simple formula (such as SUM, COUNT, or AVERAGE) applied to a numeric field of the issues from a filter or JQL, in form of number, as a gauge chart, or on a 5-star scale. You can use this gadget to display key project numbers, such as the amount of work remaining, the number of open issues, or average customer satisfaction (CSAT).",
