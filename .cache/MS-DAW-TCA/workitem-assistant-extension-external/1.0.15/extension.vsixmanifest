  <Metadata>
    <Identity Language="en-US" Id="workitem-assistant-extension-external" Publisher="MS-DAW-TCA" Version="1.0.15"/>
    <DisplayName>AI Work Item Assistant</DisplayName>
    <Description xml:space="preserve">Your backlog just got smarter. Meet the AI Work Item Assistant, powered by Azure OpenAI, to write, refine, and organize work items with speed, clarity and insights that keep your team aligned.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>copilot,ado copilot,assistant,workitem,azure boards,ai,artificial intelligence,save time,save effort,save money,employee productivity,productivity,insights,efficiency,acceptance criteria,ai assistant,analytics,analysis,augmented productivity,automation,azure devops,backlog,chat,creator,description,devops,enhance,generating,generator,gpt,llm,openai,planning,product backlog,product backlog item,product owners,reporting,requirements,requirements management,user stories,user story</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#222222"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://go.microsoft.com/fwlink/?linkid=2317610"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://go.microsoft.com/fwlink/?linkid=2317613"/>
    </Properties>
    <GalleryFlags>Public</GalleryFlags>
    <Icon>static/logos/logo.png</Icon>
    <License>assets/LICENSE.md</License>
  </Metadata>
