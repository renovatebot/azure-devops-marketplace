<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="skillflow-pr" Version="0.2.0" Publisher="SimoneBittiDev"/>
    <DisplayName>SkillFlow</DisplayName>
    <Description xml:space="preserve">Run LLM-powered Skills on Pull Requests. Define agent behavior in Markdown files and let Claude, OpenAI, Azure OpenAI, or Ollama review your code, generate tests, write documentation, and more.</Description>
    <Categories>Azure Pipelines</Categories>
    <GalleryFlags>Private</GalleryFlags>
    <Tags>AI,LLM,Pull Request,Code Review,Claude,OpenAI,LangGraph</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://github.com/simonebittidev/skillflow"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/simonebittidev/skillflow#getting-started"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/simonebittidev/skillflow"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/simonebittidev/skillflow/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/simonebittidev/skillflow"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#dcebfc"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="task/main.js" d:Source="File" Path="task/main.js" Addressable="true"/>
    <Asset Type="task/main.py" d:Source="File" Path="task/main.py" Addressable="true"/>
    <Asset Type="task/requirements.txt" d:Source="File" Path="task/requirements.txt" Addressable="true"/>
    <Asset Type="task/src/__init__.py" d:Source="File" Path="task/src/__init__.py" Addressable="true"/>
    <Asset Type="task/src/agent.py" d:Source="File" Path="task/src/agent.py" Addressable="true"/>
    <Asset Type="task/src/models/__init__.py" d:Source="File" Path="task/src/models/__init__.py" Addressable="true"/>
    <Asset Type="task/src/models/skill.py" d:Source="File" Path="task/src/models/skill.py" Addressable="true"/>
    <Asset Type="task/src/providers/__init__.py" d:Source="File" Path="task/src/providers/__init__.py" Addressable="true"/>
    <Asset Type="task/src/providers/provider_factory.py" d:Source="File" Path="task/src/providers/provider_factory.py" Addressable="true"/>
    <Asset Type="task/src/skill_loader.py" d:Source="File" Path="task/src/skill_loader.py" Addressable="true"/>
    <Asset Type="task/src/tools/__init__.py" d:Source="File" Path="task/src/tools/__init__.py" Addressable="true"/>
    <Asset Type="task/src/tools/azdo_tools.py" d:Source="File" Path="task/src/tools/azdo_tools.py" Addressable="true"/>
    <Asset Type="task/task.json" d:Source="File" Path="task/task.json" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>