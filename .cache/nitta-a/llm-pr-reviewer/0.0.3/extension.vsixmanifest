<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="llm-pr-reviewer" Publisher="nitta-a" Version="0.0.3"/>
    <DisplayName>LLM PR Reviewer</DisplayName>
    <Description xml:space="preserve">Reviews Pull Requests using LLM (Azure OpenAI / OpenAI / Anthropic / AWS Bedrock) and posts AI review comments to Azure Repos PRs.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>PR,code review,AI,LLM,OpenAI,Azure OpenAI,Anthropic,AWS Bedrock</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/nitta-a/az-pipeline-AI-review"/>
    </Properties>
    <Icon>extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="LLMReviewerTask/azureDevOps.js" d:Source="File" Path="LLMReviewerTask/azureDevOps.js" Addressable="true"/>
    <Asset Type="LLMReviewerTask/constants.js" d:Source="File" Path="LLMReviewerTask/constants.js" Addressable="true"/>
    <Asset Type="LLMReviewerTask/index.js" d:Source="File" Path="LLMReviewerTask/index.js" Addressable="true"/>
    <Asset Type="LLMReviewerTask/index.js.map" d:Source="File" Path="LLMReviewerTask/index.js.map" Addressable="true"/>
    <Asset Type="LLMReviewerTask/llm.js" d:Source="File" Path="LLMReviewerTask/llm.js" Addressable="true"/>
    <Asset Type="LLMReviewerTask/task.json" d:Source="File" Path="LLMReviewerTask/task.json" Addressable="true"/>
    <Asset Type="LLMReviewerTask/types.js" d:Source="File" Path="LLMReviewerTask/types.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>