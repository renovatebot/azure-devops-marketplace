{
    "manifestVersion": 1,
    "repository": {
        "type": "git",
        "uri": "https://github.com/info-emait/DrawIo"
    },
    "contributions": [
        {
            "id": "drawio-feature",
            "type": "ms.vss-web.feature",
            "targets": [
                "ms.vss-web.managed-features-onprem"
            ],
            "description": "Draw.io feature adds the new Draw.io hub to the Overview group.",
            "properties": {
                "name": "Draw.io",
                "userConfigurable": true,
                "hostConfigurable": true,
                "defaultState": true,
                "hostScopes": [
                    "project",
                    null
                ]
            }
        },
        {
            "id": "drawio-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.home-hub-group"
            ],
            "properties": {
                "uri": "hub.html?v=1.0.0",
                "name": "Draw.io",
                "iconName": "FlowChart",
                "order": 1
            },
            "constraints": [
                {
                    "name": "Feature",
                    "properties": {
                        "featureId": "emait.drawio.drawio-feature"
                    }
                }
            ]
        },
        {
            "id": "drawio-commit",
            "type": "ms.vss-web.external-content",
            "description": "Commit dialog",
            "properties": {
                "uri": "commit.html?v=1.0.0"
            }
        },
        {
            "id": "drawio-createfile",
            "type": "ms.vss-web.external-content",
            "description": "Create file dialog",
            "properties": {
                "uri": "createfile.html?v=1.0.0"
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write",
        "vso.code",
        "vso.code_write",
        "vso.code_status"
    ],
    "contributionTypes": []
}