<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="drawio" Version="1.0.0" Publisher="emait"/>
    <DisplayName>Draw.io</DisplayName>
    <Description xml:space="preserve">This extension brings draw.io directly into Azure DevOps, so you can view, create and edit your diagrams.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>draw,drawio,diagrams,uml,flowchart,classdiagram,architecture,diagramming,draw.io,embed</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="mailto:info.emait@gmail.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/info-emait/DrawIo"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#212121"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>img/logo.png</Icon>
    <License>License.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
