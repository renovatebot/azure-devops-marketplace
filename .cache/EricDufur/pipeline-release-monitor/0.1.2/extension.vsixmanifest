<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="pipeline-release-monitor" Publisher="EricDufur" Version="0.1.2"/>
    <DisplayName>Release Pipeline Monitor</DisplayName>
    <Description xml:space="preserve">Monitors pending and recently completed YAML multi-stage pipelines with per-stage status, awaiting-approval state, and rule-based health findings. Includes a dashboard widget and a Pipelines hub.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>pipelines,release,deployment,approvals,dashboard,widget,monitoring</Tags>
    <Icon>img/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/configuration/configuration.html" d:Source="File" Path="dist/configuration/configuration.html" Addressable="true"/>
    <Asset Type="dist/configuration/configuration.js" d:Source="File" Path="dist/configuration/configuration.js" Addressable="true"/>
    <Asset Type="dist/configuration/configuration.js.LICENSE.txt" d:Source="File" Path="dist/configuration/configuration.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/hub/hub.html" d:Source="File" Path="dist/hub/hub.html" Addressable="true"/>
    <Asset Type="dist/hub/hub.js" d:Source="File" Path="dist/hub/hub.js" Addressable="true"/>
    <Asset Type="dist/hub/hub.js.LICENSE.txt" d:Source="File" Path="dist/hub/hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/widget/widget.html" d:Source="File" Path="dist/widget/widget.html" Addressable="true"/>
    <Asset Type="dist/widget/widget.js" d:Source="File" Path="dist/widget/widget.js" Addressable="true"/>
    <Asset Type="dist/widget/widget.js.LICENSE.txt" d:Source="File" Path="dist/widget/widget.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="img/logo.png" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>