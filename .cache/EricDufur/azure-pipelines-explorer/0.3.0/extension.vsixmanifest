<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="azure-pipelines-explorer" Publisher="EricDufur" Version="0.3.0"/>
    <GalleryFlags>Public</GalleryFlags>
    <DisplayName>Pipelines Explorer</DisplayName>
    <Description xml:space="preserve">Survey YAML and classic build &amp; release pipelines across every repo. Preview YAML, inspect triggers, and flag classic pipelines that duplicate a repo that already has a YAML build.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>pipelines,build,release,yaml,classic,governance,migration,audit</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/edufur/azure-pipelines-explorer-support/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/edufur/azure-pipelines-explorer-support"/>
    </Properties>
    <Icon>img/logo.png</Icon>
    <License>LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/hub-org/orgHub.html" d:Source="File" Path="dist/hub-org/orgHub.html" Addressable="true"/>
    <Asset Type="dist/hub-org/orgHub.js" d:Source="File" Path="dist/hub-org/orgHub.js" Addressable="true"/>
    <Asset Type="dist/hub-org/orgHub.js.LICENSE.txt" d:Source="File" Path="dist/hub-org/orgHub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/hub-project/projectHub.html" d:Source="File" Path="dist/hub-project/projectHub.html" Addressable="true"/>
    <Asset Type="dist/hub-project/projectHub.js" d:Source="File" Path="dist/hub-project/projectHub.js" Addressable="true"/>
    <Asset Type="dist/hub-project/projectHub.js.LICENSE.txt" d:Source="File" Path="dist/hub-project/projectHub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="img/logo.png" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>