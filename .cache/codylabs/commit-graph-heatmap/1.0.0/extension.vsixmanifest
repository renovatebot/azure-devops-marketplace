<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="commit-graph-heatmap" Publisher="codylabs" Version="1.0.0"/>
    <DisplayName>Commit Graph — Contribution Heatmap for Azure Repos</DisplayName>
    <Description xml:space="preserve">A contribution activity heatmap for Azure Repos — see commit activity per contributor, per day, right inside Azure DevOps. The calendar view Azure Repos doesn't have.</Description>
    <GalleryFlags/>
    <Categories>Azure Repos</Categories>
    <Tags>git,commits,contribution graph,heatmap,activity,repos,analytics,calendar</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://codylabs-portfolio.pages.dev/azure-commit-graph/"/>
    </Properties>
    <Icon>img/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/hub.css" d:Source="File" Path="dist/hub.css" Addressable="true"/>
    <Asset Type="dist/hub.html" d:Source="File" Path="dist/hub.html" Addressable="true"/>
    <Asset Type="dist/hub.js" d:Source="File" Path="dist/hub.js" Addressable="true"/>
    <Asset Type="img/icon.png" d:Source="File" Path="img/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>