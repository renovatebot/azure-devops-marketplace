<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="flowcerta-validate" Publisher="flowcerta" Version="1.0.2"/>
    <DisplayName>Flowcerta Governance Gate</DisplayName>
    <Description xml:space="preserve">Validate UiPath and Power Automate workflows via the Flowcerta governance API. Returns a score and ranked findings, and fails the build on critical or high findings in blocking mode.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>rpa,uipath,power-automate,automation,governance,compliance,static-analysis,ci-cd,soc2,hipaa</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://flowcerta.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://flowcerta.com/contact/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/cjtitzer2/flowcerta-integrations"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/cjtitzer2/flowcerta-integrations/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://flowcerta.com/ci-integration/"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0d0d0d"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
    <License>LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>