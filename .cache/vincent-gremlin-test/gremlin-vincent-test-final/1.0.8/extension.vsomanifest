{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "my-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "tasks/MyTask"
            }
        },
        {
            "id": "gremlin-endpoint",
            "type": "ms.vss-endpoint.service-endpoint-type",
            "targets": [
                "ms.vss-endpoint.endpoint-types"
            ],
            "properties": {
                "name": "Gremlin",
                "displayName": "Gremlin",
                "url": {
                    "displayName": "Server URL",
                    "value": "https://api.gremlin.com",
                    "isVisible": false
                },
                "authenticationSchemes": [
                    {
                        "type": "ms.vss-endpoint.endpoint-auth-scheme-token",
                        "inputDescriptors": [
                            {
                                "id": "apitoken",
                                "name": "API Key",
                                "description": "Gremlin API Key from Team Settings > API Keys",
                                "inputMode": "passwordBox",
                                "isSecret": true,
                                "validation": {
                                    "isRequired": true,
                                    "dataType": "string"
                                }
                            }
                        ]
                    }
                ],
                "inputDescriptors": [
                    {
                        "id": "teamId",
                        "name": "Team ID",
                        "description": "Gremlin Team ID from Team Settings > Configuration",
                        "inputMode": "textBox",
                        "isSecret": false,
                        "validation": {
                            "isRequired": true,
                            "dataType": "string"
                        }
                    }
                ],
                "helpMarkDown": "Create a Gremlin service connection using an API Key and Team ID. Find these in the Gremlin web app under Team Settings."
            }
        }
    ],
    "scopes": [],
    "contributionTypes": []
}