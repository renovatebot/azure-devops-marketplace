  <Metadata>
    <Identity Language="en-US" Id="karate-dashboard-report-tab" Version="0.0.10" Publisher="SabinThomas"/>
    <DisplayName>Karate Dashboard Report Tab</DisplayName>
    <GalleryFlags/>
    <Description xml:space="preserve">Adds a Karate tab to Azure Pipelines run results with stage-wise metrics and summary links.</Description>
