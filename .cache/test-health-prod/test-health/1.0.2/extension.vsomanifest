{
    "$schema": "https://json.schemastore.org/azure-devops-extension-manifest-1.0.json",
    "manifestVersion": 1,
    "scopes": [
        "vso.code",
        "vso.project"
    ],
    "contributions": [
        {
            "id": "test-health",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-test-web.test-hub-group"
            ],
            "properties": {
                "name": "Azure Test Health (Dev)",
                "uri": "dist/index.html",
                "defaultRoute": "test-health-prod.test-health.route-hub",
                "icon": {
                    "dark": "static/icons/extension-icon.png",
                    "light": "static/icons/extension-icon.png"
                },
                "iconAsset": "test-health-prod.test-health/static/icons/extension-icon.png"
            }
        },
        {
            "id": "route-hub",
            "type": "ms.vss-web.route",
            "targets": [
                ".test-health"
            ],
            "properties": {
                "hostType": "ProjectCollection",
                "defaults": {
                    "controller": "Apps",
                    "action": "ContributedHub"
                },
                "routeTemplates": [
                    "{project}/{team}/_apps/testhealth",
                    "{project}/_apps/testhealth"
                ]
            }
        }
    ],
    "contributionTypes": []
}