    <DisplayName>Pro Gantt Chart for Azure DevOps</DisplayName>
    <Description xml:space="preserve">Interactive Gantt chart for Azure DevOps. Visualize timelines, dependencies, critical path, drag-to-reschedule, grouping, and export to PDF/PNG.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>gantt,gantt chart,timeline,project management,scheduling,dependencies,planning,roadmap,work items,boards</Tags>
    <GalleryFlags>Public</GalleryFlags>
    <Icon>images/logo.png</Icon>
  </Metadata>
