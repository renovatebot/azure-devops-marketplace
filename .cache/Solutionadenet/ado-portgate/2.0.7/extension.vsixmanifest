<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ado-portgate" Version="2.0.7" Publisher="Solutionadenet"/>
    <DisplayName>ADO PortGate DevOps</DisplayName>
    <Description xml:space="preserve">Seamlessly manage Azure DevOps projects, work items, identity, and security from a unified portal hub.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>azure devops,work items,project management,portal,hub</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#003d70"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://solutionade.net/support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://solutionade.net"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://solutionade.net"/>
    </Properties>
    <Icon>src/assets/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/devops-app/index.html" d:Source="File" Path="dist/devops-app/index.html" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/ado-dark.png" d:Source="File" Path="dist/devops-app/assets/ado-dark.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/ado-light.png" d:Source="File" Path="dist/devops-app/assets/ado-light.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/Ado-White.png" d:Source="File" Path="dist/devops-app/assets/Ado-White.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/avatar.png" d:Source="File" Path="dist/devops-app/assets/avatar.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/azure-DevOps.png" d:Source="File" Path="dist/devops-app/assets/azure-DevOps.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/favicon.ico" d:Source="File" Path="dist/devops-app/assets/favicon.ico" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/Icon.png" d:Source="File" Path="dist/devops-app/assets/Icon.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/logo.png" d:Source="File" Path="dist/devops-app/assets/logo.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/LogoTagline.png" d:Source="File" Path="dist/devops-app/assets/LogoTagline.png" Addressable="true"/>
    <Asset Type="dist/devops-app/assets/upload.png" d:Source="File" Path="dist/devops-app/assets/upload.png" Addressable="true"/>
    <Asset Type="src/assets/logo.png" d:Source="File" Path="src/assets/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="src/assets/logo.png" Addressable="true"/>
    <Asset Type="src/assets/ado-light.png" d:Source="File" Path="src/assets/ado-light.png" Addressable="true"/>
    <Asset Type="src/assets/ado-dark.png" d:Source="File" Path="src/assets/ado-dark.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots" d:Source="File" Path="screenshots/screenshot1.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
