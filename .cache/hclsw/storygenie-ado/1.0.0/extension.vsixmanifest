<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="storygenie-ado" Publisher="hclsw" Version="1.0.0"/>
    <DisplayName>HCLSW StoryGenie</DisplayName>
    <Description xml:space="preserve">AI-assisted Azure DevOps Board extension that generates implementation-ready child User Stories or Product Backlog Items from Feature work items.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Icon>dist/assets/storygenie-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/assets/storygenie-icon.png" d:Source="File" Path="dist/assets/storygenie-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="dist/assets/storygenie-icon.png" Addressable="true"/>
    <Asset Type="dist/lib/SDK.min.js" d:Source="File" Path="dist/lib/SDK.min.js" Addressable="true"/>
    <Asset Type="dist/lib/VSS.SDK.min.js" d:Source="File" Path="dist/lib/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="dist/storygenie-menu-provider.html" d:Source="File" Path="dist/storygenie-menu-provider.html" Addressable="true"/>
    <Asset Type="dist/storygenie-menu-provider.js" d:Source="File" Path="dist/storygenie-menu-provider.js" Addressable="true"/>
    <Asset Type="dist/work-item-form-page.css" d:Source="File" Path="dist/work-item-form-page.css" Addressable="true"/>
    <Asset Type="dist/work-item-form-page.html" d:Source="File" Path="dist/work-item-form-page.html" Addressable="true"/>
    <Asset Type="dist/work-item-form-page.js" d:Source="File" Path="dist/work-item-form-page.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>