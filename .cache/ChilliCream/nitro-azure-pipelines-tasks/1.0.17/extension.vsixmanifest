<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="nitro-azure-pipelines-tasks" Version="1.0.17" Publisher="ChilliCream"/>
    <DisplayName>Nitro for Azure Pipelines</DisplayName>
    <Description xml:space="preserve">Publish, upload, and validate GraphQL schemas, Fusion configurations, clients, OpenAPI and MCP Feature collections using Nitro.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>graphql,nitro,chillicream,hotchocolate,fusion</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://chillicream.com/products/nitro"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/ChilliCream/nitro-azure-pipelines-tasks"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/ChilliCream/nitro-azure-pipelines-tasks/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/ChilliCream/nitro-azure-pipelines-tasks/blob/main/LICENSE"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/ChilliCream/nitro-azure-pipelines-tasks"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>