            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "tasks/NitroMcpPublishV16"
            }
        },
        {
            "id": "nitro-mcp-upload-v16",
            "type": "ms.vss-distributed-task.task",
