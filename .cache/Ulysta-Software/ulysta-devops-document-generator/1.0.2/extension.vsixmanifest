<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ulysta-devops-document-generator" Publisher="Ulysta-Software" Version="1.0.2"/>
    <DisplayName>Ulysta DevOps Document Generator</DisplayName>
    <Description xml:space="preserve">Ulysta DevOps Document Generator creates Word docs from Azure DevOps data using customizable templates, enabling consistent, standards-compliant project documentation in minutes.</Description>
    <GalleryFlags>Public Paid</GalleryFlags>
    <Tags>__BYOLENFORCED</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="30"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="mailto:support@ulysta.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.ulysta.com/msa/msa.html"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://www.ulysta.com/msa/msa.html"/>
    </Properties>
    <Categories>Azure Boards,Azure Test Plans</Categories>
    <Icon>src/assets/logo.png</Icon>
    <License>LICENSE.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="src/assets/logo.png" d:Source="File" Path="src/assets/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="src/assets/logo.png" Addressable="true"/>
    <Asset Type="build/index-DkRiEqMu.js.map" d:Source="File" Path="build/index-DkRiEqMu.js.map" Addressable="true"/>
    <Asset Type="build/index.html" d:Source="File" Path="build/index.html" Addressable="true"/>
    <Asset Type="marketing/screenshots/Builder.png" d:Source="File" Path="marketing/screenshots/Builder.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/combined-1.png" d:Source="File" Path="marketing/screenshots/combined-1.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/combined-2.png" d:Source="File" Path="marketing/screenshots/combined-2.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/combined-3.png" d:Source="File" Path="marketing/screenshots/combined-3.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Document.png" d:Source="File" Path="marketing/screenshots/Document.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Documents.png" d:Source="File" Path="marketing/screenshots/Documents.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Help_fields.png" d:Source="File" Path="marketing/screenshots/Help_fields.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Help_syntax.png" d:Source="File" Path="marketing/screenshots/Help_syntax.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Template.png" d:Source="File" Path="marketing/screenshots/Template.png" Addressable="true"/>
    <Asset Type="marketing/screenshots/Templates.png" d:Source="File" Path="marketing/screenshots/Templates.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.PrivacyPolicy" d:Source="File" Path="PRIVACY.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Pricing" d:Source="File" Path="PRICING.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>