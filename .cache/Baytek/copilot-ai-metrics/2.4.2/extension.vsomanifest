{
    "manifestVersion": 1,
    "CustomerQnASupport": {
        "enableqna": true,
        "url": "https://marketplace.visualstudio.com/items?itemName=baytek.agile-analytics"
    },
    "contributions": [
        {
            "id": "copilot-ai-metrics-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Copilot AI Metrics",
                "uri": "build/index.html",
                "icon": "images/copilotAI.png"
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.analytics"
    ],
    "contributionTypes": []
}