  <Metadata>
    <Identity Language="en-US" Id="copilot-ai-metrics" Publisher="baytek" Version="2.0.6"/>
    <DisplayName>Copilot AI Metrics</DisplayName>
    <Description xml:space="preserve">Free GitHub Copilot analytics inside Azure DevOps. Acceptance rates, adoption funnels, seat efficiency, CLI, Chat, ROI and leaderboards. No backend. No data leaves your browser.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards,Azure Repos</Categories>
    <Tags>copilot,ai,metrics,github copilot,analytics,adoption,dashboard,free,developer productivity,acceptance rate,ai metrics,copilot usage,team analytics,seat management,ROI,agile analytics,baytek</Tags>
