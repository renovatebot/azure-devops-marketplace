  <Metadata>
    <Identity Language="en-US" Id="status-portal-azure-devops" Version="1.0.6" Publisher="Baytek"/>
    <DisplayName>Status Portal</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Manage your public status page directly from Azure DevOps. Incidents, maintenance windows, subscriber notifications, and a live public status page — all in one hub.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>status page,incident management,maintenance,uptime,monitoring,notifications,subscribers,service health,status</Tags>
    <Properties>
