  <Metadata>
    <Identity Language="en-US" Id="agile-analytics" Publisher="Baytek" Version="3.2.7"/>
    <DisplayName>Agile Analytics</DisplayName>
    <Description xml:space="preserve">15+ analytics views for Azure DevOps — velocity, cycle time, Monte Carlo forecasting, WIP monitor, flow metrics, and an optional AI sprint assistant.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>agile,analytics,sprint,velocity,cycle time,flow metrics,monte carlo,wip,burndown,reporting,scrum,kanban,forecasting,team health,retrospective</Tags>
    <Properties>
