      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/MrHenrySword/agile-analytics-ado#getting-started"/>
    </Properties>
    <Icon>marketplace/images/logo.png</Icon>
    <License>marketplace/license.md</License>
  </Metadata>
