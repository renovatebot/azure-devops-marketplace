  <Metadata>
    <Identity Language="en-US" Id="agile-analytics" Publisher="Baytek" Version="6.4.4"/>
    <DisplayName>Agile Analytics</DisplayName>
    <Description xml:space="preserve">Sprint planning and flow analytics for Azure DevOps — Next Sprint Planning (capacity + Monte Carlo + cycle-time reality check), Flow Efficiency, cycle time, SLEs, Monte Carlo, WIP, and 15+ views.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>__DoNotDownload,agile,analytics,sprint,sprint planning,next sprint planning,velocity,cycle time,flow metrics,flow efficiency,service level expectations,monte carlo,wip,burndown,reporting,scrum,kanban,forecasting,team health,retrospective</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://ado-analytics.baytekdev.com/privacy/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://ado-analytics.baytekdev.com/terms/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://ado-analytics.baytekdev.com/support/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://ado-analytics.baytekdev.com/install/"/>
    </Properties>
    <Icon>marketplace/images/logo.png</Icon>
    <License>marketplace/license.md</License>
  </Metadata>
