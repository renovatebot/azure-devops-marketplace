<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="fortify-fpr-viewer" Publisher="PetronasDigital" Version="1.0.3"/>
    <DisplayName>Fortify FPR Results Viewer</DisplayName>
    <Description xml:space="preserve">View Fortify DAST/SAST FPR scan results directly in Azure DevOps build summary. Supports multiple FPR files with tabbed view.</Description>
    <Categories>Azure Pipelines</Categories>
    <Icon>img/icon128.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/tab/tab.html" d:Source="File" Path="dist/tab/tab.html" Addressable="true"/>
    <Asset Type="dist/tab/tab.js" d:Source="File" Path="dist/tab/tab.js" Addressable="true"/>
    <Asset Type="dist/tab/tab.js.LICENSE.txt" d:Source="File" Path="dist/tab/tab.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/tab/tab.js.map" d:Source="File" Path="dist/tab/tab.js.map" Addressable="true"/>
    <Asset Type="img/gen_icons.py" d:Source="File" Path="img/gen_icons.py" Addressable="true"/>
    <Asset Type="img/icon.png" d:Source="File" Path="img/icon.png" Addressable="true"/>
    <Asset Type="img/icon128.png" d:Source="File" Path="img/icon128.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/icon128.png" Addressable="true"/>
    <Asset Type="img/icon512.png" d:Source="File" Path="img/icon512.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Large" d:Source="File" Path="img/icon512.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>