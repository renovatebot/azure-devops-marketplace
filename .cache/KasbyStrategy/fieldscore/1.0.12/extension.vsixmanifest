<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="fieldscore" Publisher="KasbyStrategy" Version="1.0.12"/>
    <DisplayName>FieldScore</DisplayName>
    <Description xml:space="preserve">Configurable value score calculator for Azure DevOps work items. Define a custom formula using any numeric fields and automatically calculate scores on the work item form.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>score,value,WSJF,RICE,priority,calculation,backlog,ranking,work items,formula</Tags>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/lib/VSS.SDK.min.js" d:Source="File" Path="dist/lib/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="dist/observer/observer.html" d:Source="File" Path="dist/observer/observer.html" Addressable="true"/>
    <Asset Type="dist/observer/observer.js" d:Source="File" Path="dist/observer/observer.js" Addressable="true"/>
    <Asset Type="dist/settings/settings.html" d:Source="File" Path="dist/settings/settings.html" Addressable="true"/>
    <Asset Type="dist/settings/settings.js" d:Source="File" Path="dist/settings/settings.js" Addressable="true"/>
    <Asset Type="dist/settings/settings.js.LICENSE.txt" d:Source="File" Path="dist/settings/settings.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="images/Fieldscore.gif" d:Source="File" Path="images/Fieldscore.gif" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="images/settings-screenshot.png" d:Source="File" Path="images/settings-screenshot.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>