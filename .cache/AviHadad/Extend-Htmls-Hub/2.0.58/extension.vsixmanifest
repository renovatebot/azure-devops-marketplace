<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="Extend-Htmls-Hub" Version="2.0.58" Publisher="AviHadad"/>
    <DisplayName>Extend Htmls Hub View Control</DisplayName>
    <Description xml:space="preserve">HTML Report Viewer — publish, organise and view HTML reports inside Azure DevOps. Supports folders, tabbed reports, pipeline publishing, and admin permissions.</Description>
    <Categories>Azure Boards,Azure Pipelines</Categories>
    <Tags>Hub,Html,Reports,Pipelines,Usability</Tags>
    <Icon>images/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services" Version="[16.0,)"/>
  </Installation>
  <Assets>
    <Asset Type="dist/Config/Config.html" d:Source="File" Path="dist/Config/Config.html" Addressable="true"/>
    <Asset Type="dist/Config/Config.js" d:Source="File" Path="dist/Config/Config.js" Addressable="true"/>
    <Asset Type="dist/Config/Config.js.map" d:Source="File" Path="dist/Config/Config.js.map" Addressable="true"/>
    <Asset Type="dist/Hub/Hub.html" d:Source="File" Path="dist/Hub/Hub.html" Addressable="true"/>
    <Asset Type="dist/Hub/Hub.js" d:Source="File" Path="dist/Hub/Hub.js" Addressable="true"/>
    <Asset Type="dist/Hub/Hub.js.map" d:Source="File" Path="dist/Hub/Hub.js.map" Addressable="true"/>
    <Asset Type="dist/images/logo.png" d:Source="File" Path="dist/images/logo.png" Addressable="true"/>
    <Asset Type="images/logo.png" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="docs/REQUIREMENTS.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>