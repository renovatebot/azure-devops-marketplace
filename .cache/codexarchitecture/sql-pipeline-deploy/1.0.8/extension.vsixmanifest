<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="sql-pipeline-deploy" Version="1.0.8" Publisher="codexarchitecture"/>
    <DisplayName>SQL Pipeline Deploy for Azure DevOps</DisplayName>
    <GalleryFlags/>
    <Description xml:space="preserve">Keep code and database in sync on every release. Run hand-written SQL release scripts after your app deploy — same pipeline, deployment ledger. Free: deploy + ledger. Pro: dry-run + summary artifact.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>sql,database,release,deployment,sql server,pipeline</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://codex-architecture.com/sql-pipeline-deploy/setup"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://codex-architecture.com/pricing"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://codex-architecture.com/support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://codex-architecture.com/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://dev.azure.com/jdelugo/ReleaseScripts/_git/ReleaseScripts"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="pricing.md" d:Source="File" Path="pricing.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Pricing" d:Source="File" Path="pricing.md" Addressable="true"/>
    <Asset Type="images/create-icon.ps1" d:Source="File" Path="images/create-icon.ps1" Addressable="true"/>
    <Asset Type="images/ensure-icons.ps1" d:Source="File" Path="images/ensure-icons.ps1" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="images/README.md" d:Source="File" Path="images/README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>