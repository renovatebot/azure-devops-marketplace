<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="wcom-pullrequest-hub" Version="0.1.38" Publisher="WCOM"/>
    <DisplayName>WCOM PullRequest Hub</DisplayName>
    <Description xml:space="preserve">Azure DevOps pull request hub: a single place to browse and filter pull requests across repositories in your project. Built and maintained by WCOM.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Repos</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0a2740"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/WCOMAB"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://github.com/WCOMAB"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/WCOMAB"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/WCOMAB"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://opensource.org/licenses/MIT"/>
    </Properties>
    <Tags>wcom,pull requests,pull request,azure repos,code review</Tags>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist-extension/hub.html" d:Source="File" Path="dist-extension/hub.html" Addressable="true"/>
    <Asset Type="dist-extension/hub.js" d:Source="File" Path="dist-extension/hub.js" Addressable="true"/>
    <Asset Type="dist-extension/hub.js.map" d:Source="File" Path="dist-extension/hub.js.map" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>