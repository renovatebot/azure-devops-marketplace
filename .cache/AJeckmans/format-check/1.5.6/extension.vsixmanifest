<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="format-check" Version="1.5.6" Publisher="ajeckmans"/>
    <DisplayName>Format Check dotnet</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">This task uses 'dotnet format' for code compliance validation.</Description>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/ajeckmans/format-check-task"/>
    </Properties>
    <Categories>Azure Repos,Azure Pipelines</Categories>
    <Icon>images/my-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="format-check/dist/101.index.js" d:Source="File" Path="format-check/dist/101.index.js" Addressable="true"/>
    <Asset Type="format-check/dist/index.js" d:Source="File" Path="format-check/dist/index.js" Addressable="true"/>
    <Asset Type="format-check/dist/package.json" d:Source="File" Path="format-check/dist/package.json" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/my-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>