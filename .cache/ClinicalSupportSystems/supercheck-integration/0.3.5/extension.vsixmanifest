<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="supercheck-integration" Publisher="ClinicalSupportSystems" Version="0.3.5"/>
    <DisplayName>Supercheck for Azure DevOps</DisplayName>
    <Description xml:space="preserve">Integrate Supercheck uptime monitoring, Playwright browser tests, and k6 performance tests into your Azure DevOps pipelines.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>supercheck,monitoring,testing,playwright,k6,uptime</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://supercheck.io"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/ClinicalSupportSystems/supercheck-azdo"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://supercheck.io/docs"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/ClinicalSupportSystems/supercheck-azdo"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="src/widget/configuration.html" d:Source="File" Path="src/widget/configuration.html" Addressable="true"/>
    <Asset Type="src/widget/configuration.js" d:Source="File" Path="src/widget/configuration.js" Addressable="true"/>
    <Asset Type="src/widget/lib/VSS.SDK.min.js" d:Source="File" Path="src/widget/lib/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="src/widget/widget.css" d:Source="File" Path="src/widget/widget.css" Addressable="true"/>
    <Asset Type="src/widget/widget.html" d:Source="File" Path="src/widget/widget.html" Addressable="true"/>
    <Asset Type="src/widget/widget.js" d:Source="File" Path="src/widget/widget.js" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>