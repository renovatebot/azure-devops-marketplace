<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="qualys-security-scanner" Version="1.0.0" Publisher="qualys-ext"/>
    <DisplayName>Qualys Security Scanner</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Integrate Qualys Container Security and SCA scanning into your Azure Pipelines</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>security,container,sca,vulnerability,qualys,devsecops,docker,sbom</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/nelssec/qualys-ado"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#1a1a2e"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="ui/scan-results-tab/scan-results-tab.html" d:Source="File" Path="ui/scan-results-tab/scan-results-tab.html" Addressable="true"/>
    <Asset Type="ui/scan-results-tab/scan-results-tab.js" d:Source="File" Path="ui/scan-results-tab/scan-results-tab.js" Addressable="true"/>
    <Asset Type="ui/scan-results-tab/scan-results-tab.js.map" d:Source="File" Path="ui/scan-results-tab/scan-results-tab.js.map" Addressable="true"/>
    <Asset Type="images/extension-icon-original.png" d:Source="File" Path="images/extension-icon-original.png" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="images/qualys-logo.png" d:Source="File" Path="images/qualys-logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>