<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ado-currency-display-control" Version="1.0.3" Publisher="deenuy"/>
    <DisplayName>ADO Currency Display Control</DisplayName>
    <Description xml:space="preserve">Render any Integer or Double field on the work item form as a formatted currency value (e.g. $2K, €1.5M). Reusable across BU Impact, Estimated Cost, Actual Cost, or any custom numeric field.</Description>
    <Categories>Azure Boards</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Tags>Custom Control,Work Item,Currency,Format,Numeric,PMO,Portfolio</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/deenuy/ado-query-rollup-widget"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/deenuy/ado-query-rollup-widget/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacy" Value="https://github.com/deenuy/ado-query-rollup-widget/blob/main/PRIVACY.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>marketplace/logo.png</Icon>
    <License>LICENSE.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services.Cloud"/>
    <InstallationTarget Id="Microsoft.TeamFoundation.Server" Version="[15.0,)"/>
  </Installation>
  <Assets>
    <Asset Type="marketplace/overview.md" d:Source="File" Path="marketplace/overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="marketplace/overview.md" Addressable="true"/>
    <Asset Type="marketplace/logo.png" d:Source="File" Path="marketplace/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="marketplace/logo.png" Addressable="true"/>
    <Asset Type="LICENSE.md" d:Source="File" Path="LICENSE.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE.md" Addressable="true"/>
    <Asset Type="dist/control.js" d:Source="File" Path="dist/control.js" Addressable="true"/>
    <Asset Type="dist/control.js.map" d:Source="File" Path="dist/control.js.map" Addressable="true"/>
    <Asset Type="static/.DS_Store" d:Source="File" Path="static/.DS_Store" Addressable="true"/>
    <Asset Type="static/control.html" d:Source="File" Path="static/control.html" Addressable="true"/>
    <Asset Type="static/css/control.css" d:Source="File" Path="static/css/control.css" Addressable="true"/>
    <Asset Type="lib/VSS.SDK.js" d:Source="File" Path="lib/VSS.SDK.js" Addressable="true"/>
    <Asset Type="lib/VSS.SDK.min.js" d:Source="File" Path="lib/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>