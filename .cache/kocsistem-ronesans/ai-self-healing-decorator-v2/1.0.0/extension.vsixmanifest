<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ai-self-healing-decorator-v2" Version="1.0.0" Publisher="kocsistem-ronesans"/>
    <DisplayName>Auto Self-Healing Pipeline Decorator</DisplayName>
    <Description xml:space="preserve">Fail olan Azure DevOps joblarına otomatik AI log analizi ekler.</Description>
    <Categories>Azure Pipelines</Categories>
    <Icon>icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="self-healing-step.yml" d:Source="File" Path="self-healing-step.yml" Addressable="true"/>
