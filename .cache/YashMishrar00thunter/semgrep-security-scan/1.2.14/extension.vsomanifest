{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "semgrep-scan-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "semgrepScan"
            }
        },
        {
            "id": "semgrep-hub-group",
            "type": "ms.vss-web.hub-group",
            "description": "Semgrep security scan configuration",
            "targets": [
                "ms.vss-web.project-hub-groups"
            ],
            "properties": {
                "name": "Semgrep",
                "order": 85,
                "icon": "asset://extension/icons/icon.png"
            }
        },
        {
            "id": "semgrep-pipeline-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-build-web.build-release-hub-group"
            ],
            "properties": {
                "name": "Semgrep Config",
                "order": 95,
                "uri": "semgrepScan/ui/task-inputs.html"
            }
        },
        {
            "id": "semgrep-config-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "YashMishrar00thunter.semgrep-security-scan.semgrep-hub-group"
            ],
            "properties": {
                "name": "Scan Configuration",
                "order": 1,
                "uri": "semgrepScan/ui/task-inputs.html"
            }
        }
    ],
    "scopes": [],
    "contributionTypes": []
}