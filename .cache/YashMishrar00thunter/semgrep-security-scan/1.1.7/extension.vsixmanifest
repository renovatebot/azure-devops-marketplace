    <Asset Type="semgrepScan/scripts/metrics.py" d:Source="File" Path="semgrepScan/scripts/metrics.py" Addressable="true"/>
    <Asset Type="semgrepScan/scripts/pr_creator.py" d:Source="File" Path="semgrepScan/scripts/pr_creator.py" Addressable="true"/>
    <Asset Type="semgrepScan/scripts/requirements.txt" d:Source="File" Path="semgrepScan/scripts/requirements.txt" Addressable="true"/>
    <Asset Type="semgrepScan/scripts/scan_executor.py" d:Source="File" Path="semgrepScan/scripts/scan_executor.py" Addressable="true"/>
    <Asset Type="semgrepScan/scripts/summary_generator.py" d:Source="File" Path="semgrepScan/scripts/summary_generator.py" Addressable="true"/>
    <Asset Type="semgrepScan/scripts/ticket_creator.py" d:Source="File" Path="semgrepScan/scripts/ticket_creator.py" Addressable="true"/>
    <Asset Type="semgrepScan/task.js" d:Source="File" Path="semgrepScan/task.js" Addressable="true"/>
    <Asset Type="semgrepScan/task.json" d:Source="File" Path="semgrepScan/task.json" Addressable="true"/>
    <Asset Type="semgrepScan/task.ts" d:Source="File" Path="semgrepScan/task.ts" Addressable="true"/>
    <Asset Type="semgrepScan/ui/README.md" d:Source="File" Path="semgrepScan/ui/README.md" Addressable="true"/>
    <Asset Type="semgrepScan/ui/task-inputs.css" d:Source="File" Path="semgrepScan/ui/task-inputs.css" Addressable="true"/>
