      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://outcomemet.co.uk/privacy-and-policies"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://outcomemet.co.uk/terms-and-conditions"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0052cc"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Tags>OKR,outcomes,roadmap,milestones,portfolio,PMO,Gantt,dependencies,planning,timeline,executive,strategy,Project Online,programme management,cascade risk,prioritisation,prioritization,backlog ordering,drag and drop</Tags>
    <Icon>images/icon.png</Icon>
