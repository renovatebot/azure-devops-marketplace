  <Metadata>
    <Identity Language="en-US" Id="outcomemap" Publisher="outcomemet" Version="1.0.7"/>
    <DisplayName>OutcomeMap</DisplayName>
    <Description xml:space="preserve">OKR hierarchy, Gantt roadmaps, milestones &amp; portfolio dashboard inside Azure DevOps. The Project Online replacement built for PMO teams. Free tier available.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://outcomemap.co.uk"/>
