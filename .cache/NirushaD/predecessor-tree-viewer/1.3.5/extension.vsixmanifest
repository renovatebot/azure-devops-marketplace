<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="predecessor-tree-viewer" Publisher="NirushaD" Version="1.3.5"/>
    <DisplayName>Predecessor Tree Viewer</DisplayName>
    <Description xml:space="preserve">Visualise the full predecessor dependency chain for any Test Case, Bug, or Change Request — directly from the work item form or the Boards hub.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>work items,dependencies,predecessor,tree,test case,bug,traceability</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/NirushaD/ado-predecessor-tree/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/NirushaD/ado-predecessor-tree#readme"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/NirushaD/ado-predecessor-tree"/>
    </Properties>
    <Icon>images/icon.png</Icon>
    <License>LICENSE.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/form-panel.html" d:Source="File" Path="dist/form-panel.html" Addressable="true"/>
    <Asset Type="dist/form-panel.js" d:Source="File" Path="dist/form-panel.js" Addressable="true"/>
    <Asset Type="dist/form-panel.js.LICENSE.txt" d:Source="File" Path="dist/form-panel.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/hub.html" d:Source="File" Path="dist/hub.html" Addressable="true"/>
    <Asset Type="dist/hub.js" d:Source="File" Path="dist/hub.js" Addressable="true"/>
    <Asset Type="dist/hub.js.LICENSE.txt" d:Source="File" Path="dist/hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="images/icon-256.png" d:Source="File" Path="images/icon-256.png" Addressable="true"/>
    <Asset Type="images/icon-512.png" d:Source="File" Path="images/icon-512.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>