<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="jenkins-predictive-dashboard" Version="1.7.0" Publisher="snehakothawade"/>
    <DisplayName>Jenkins AI Predictive Dashboard</DisplayName>
    <Description xml:space="preserve">Advanced failure prediction and stage-level analytics for Jenkins pipelines.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>Jenkins,CI/CD,AI,Pipeline Analytics,Failure Prediction,DevOps,Monitoring</Tags>
    <Icon>extension_icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="index.html" d:Source="File" Path="index.html" Addressable="true"/>
    <Asset Type="extension_icon.png" d:Source="File" Path="extension_icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="extension_icon.png" Addressable="true"/>
    <Asset Type="photo/Screenshot_1.png" d:Source="File" Path="photo/Screenshot_1.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.1" d:Source="File" Path="photo/Screenshot_1.png" Addressable="true"/>
    <Asset Type="photo/Screenshot_2.png" d:Source="File" Path="photo/Screenshot_2.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.2" d:Source="File" Path="photo/Screenshot_2.png" Addressable="true"/>
    <Asset Type="photo/Screenshot_3.png" d:Source="File" Path="photo/Screenshot_3.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.3" d:Source="File" Path="photo/Screenshot_3.png" Addressable="true"/>
    <Asset Type="README.md" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="README.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>