    <Asset Type="dist/devops/overview.md" d:Source="File" Path="dist/devops/overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="dist/devops/overview.md" Addressable="true"/>
    <Asset Type="dist/devops/vss-extension.json" d:Source="File" Path="dist/devops/vss-extension.json" Addressable="true"/>
    <Asset Type="dist/index.html" d:Source="File" Path="dist/index.html" Addressable="true"/>
