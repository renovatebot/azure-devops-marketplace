{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "status-indicator",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog",
                ".status-indicator.config"
            ],
            "properties": {
                "name": "Status Indicator",
                "description": "Track simple red, amber, green status items directly from a dashboard.",
                "catalogIconUrl": "static/catalog-icon.png",
                "previewImageUrl": "static/preview.png",
                "uri": "dist/src/ado/status-widget.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 2
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 2
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 4
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "status-indicator.config",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "name": "Status Indicator configuration",
                "uri": "dist/src/ado/status-config.html"
            }
        },
        {
            "id": "pi-ready",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog",
                ".pi-ready.config"
            ],
            "properties": {
                "name": "PI Readiness Checklist",
                "description": "Track the PI readiness checklist directly from a dashboard.",
                "catalogIconUrl": "static/catalog-icon.png",
                "previewImageUrl": "static/preview.png",
                "uri": "dist/src/ado/pi-ready-widget.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 4
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 4
                    },
                    {
                        "rowSpan": 4,
                        "columnSpan": 4
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 6
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 8
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "pi-ready.config",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "name": "PI Readiness Checklist configuration",
                "uri": "dist/src/ado/pi-ready-config.html"
            }
        },
        {
            "id": "slide",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog",
                ".slide.config"
            ],
            "properties": {
                "name": "Slide",
                "description": "Create and navigate a small multi-page slide deck on a dashboard.",
                "catalogIconUrl": "static/catalog-icon.png",
                "previewImageUrl": "static/preview.png",
                "uri": "dist/src/ado/slide-widget.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 4
                    },
                    {
                        "rowSpan": 4,
                        "columnSpan": 4
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 5
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "slide.config",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "name": "Slide configuration",
                "uri": "dist/src/ado/slide-config.html"
            }
        }
    ],
    "scopes": [],
    "contributionTypes": []
}