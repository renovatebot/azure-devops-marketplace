{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "status-indicator",
            "type": "ms.vss-dashboards-web.widget",
            "targets": [
                "ms.vss-dashboards-web.widget-catalog",
                ".status-indicator.config"
            ],
            "properties": {
                "name": "Status Indicator",
                "description": "Track simple red, amber, green status items directly from a dashboard.",
                "catalogIconUrl": "static/catalog-icon.png",
                "previewImageUrl": "static/preview.png",
                "uri": "dist/src/ado/status-widget.html",
                "isNameConfigurable": true,
                "supportedSizes": [
                    {
                        "rowSpan": 2,
                        "columnSpan": 2
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 2
                    },
                    {
                        "rowSpan": 3,
                        "columnSpan": 3
                    },
                    {
                        "rowSpan": 2,
                        "columnSpan": 4
                    }
                ],
                "supportedScopes": [
                    "project_team"
                ]
            }
        },
        {
            "id": "status-indicator.config",
            "type": "ms.vss-dashboards-web.widget-configuration",
            "targets": [
                "ms.vss-dashboards-web.widget-configuration"
            ],
            "properties": {
                "name": "Status Indicator configuration",
                "uri": "dist/src/ado/status-config.html"
            }
        }
    ],
    "scopes": [],
    "contributionTypes": []
}