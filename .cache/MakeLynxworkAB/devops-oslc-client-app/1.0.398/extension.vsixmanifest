    <DisplayName>Lynxwork Azure DevOps OSLC Client</DisplayName>
    <Description xml:space="preserve">Connect Azure DevOps with Polarion, DOORS Next, Teamcenter, JIRA, Codebeamer, and other OSLC tools</Description>
    <Categories>Azure Boards</Categories>
    <Tags>OSLC,Polarion integration,JIRA integration,DOORS Next integration,IBM ELM integration,Teamcenter integration,Codebeamer integration,ALM integration,PLM integration,requirements traceability,digital thread,systems engineering,application lifecycle management,requirements management,engineering lifecycle management,work item traceability,cross-tool traceability,enterprise integration</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="mailto:contact@lynxwork.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://www.linkedin.com/company/lynxwork"/>
    </Properties>
