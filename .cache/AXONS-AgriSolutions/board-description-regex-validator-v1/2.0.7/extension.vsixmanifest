<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="board-description-regex-validator-v1" Version="2.0.7" Publisher="AXONS-AgriSolutions"/>
    <DisplayName>Commit State Description Validator</DisplayName>
    <Description xml:space="preserve">Validates required Description fields before allowing work items to transition to Committed state in Azure Boards.</Description>
    <Categories>Azure Boards</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://AXONS-FIT-Business-and-CPTG@dev.azure.com/AXONS-FIT-Business-and-CPTG/Wee/_git/vsts-description-validator"/>
    </Properties>
    <Icon>src/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="src/index.html" d:Source="File" Path="src/index.html" Addressable="true"/>
    <Asset Type="src/logo.png" d:Source="File" Path="src/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="src/logo.png" Addressable="true"/>
    <Asset Type="src/validator.js" d:Source="File" Path="src/validator.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>