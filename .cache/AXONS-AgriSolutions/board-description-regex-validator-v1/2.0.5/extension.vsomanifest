{
    "manifestVersion": 1,
    "keywords": [
        "validation",
        "description",
        "committed",
        "work item",
        "azure boards"
    ],
    "scopes": [
        "vso.project",
        "vso.work",
        "vso.work_write"
    ],
    "license": "LICENSE",
    "repository": {
        "type": "git",
