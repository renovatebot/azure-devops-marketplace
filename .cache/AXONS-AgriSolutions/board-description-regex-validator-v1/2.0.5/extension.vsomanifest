    },
    "contributions": [
        {
            "id": "commit-state-validator-observer",
            "type": "ms.vss-work-web.work-item-form-observer",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "uri": "src/index.html"
            }
        }
    ],
    "contributionTypes": []
}