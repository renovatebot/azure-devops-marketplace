{
    "manifestVersion": 1,
    "scopes": [
        "vso.work",
        "vso.work_write"
    ],
    "contributions": [
        {
            "id": "project-dashboard-hub",
            "type": "ms.vss-web.hub",
            "description": "Project Progress Dashboard — daily status, delivery tracking, outstanding bugs",
            "targets": [
                "ms.vss-web.project-hub-group"
            ],
            "properties": {
                "name": "Project Dashboard",
                "order": 100,
                "uri": "html/dashboard.html",
                "icon": {
                    "light": "images/icon-light.png",
                    "dark": "images/icon-dark.png"
                }
            }
        },
        {
            "id": "project-dashboard-kpi-hub",
            "type": "ms.vss-web.hub",
            "description": "KPI Dashboard — management metrics and charts",
            "targets": [
                "ms.vss-web.project-hub-group"
            ],
            "properties": {
                "name": "Project KPIs",
                "order": 101,
                "uri": "html/kpi.html",
                "icon": {
                    "light": "images/icon-light.png",
                    "dark": "images/icon-dark.png"
                }
            }
        }
    ],
    "CustomerQnASupport": {
        "enableqna": true,
        "url": "https://scriptpadservices.com/support"
    },
    "contributionTypes": []
}