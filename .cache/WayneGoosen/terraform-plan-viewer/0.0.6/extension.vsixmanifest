<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="terraform-plan-viewer" Version="0.0.6" Publisher="WayneGoosen"/>
    <DisplayName>Terraform Plan Viewer</DisplayName>
    <Description xml:space="preserve">Visualize Terraform plan output in Azure DevOps pipelines with a beautiful UI showing what will be changed, added, or deleted.</Description>
    <Categories>Azure Pipelines</Categories>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/tab/lib/VSS.SDK.min.js" d:Source="File" Path="dist/tab/lib/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="dist/tab/tab.css" d:Source="File" Path="dist/tab/tab.css" Addressable="true"/>
    <Asset Type="dist/tab/tab.html" d:Source="File" Path="dist/tab/tab.html" Addressable="true"/>
    <Asset Type="dist/tab/tab.js" d:Source="File" Path="dist/tab/tab.js" Addressable="true"/>
    <Asset Type="dist/tab/tab.js.map" d:Source="File" Path="dist/tab/tab.js.map" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="images/extension-icon.png.txt" d:Source="File" Path="images/extension-icon.png.txt" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>