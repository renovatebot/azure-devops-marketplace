<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="terraform-plan-viewer" Version="0.0.10" Publisher="WayneGoosen"/>
    <DisplayName>Terraform Plan Viewer</DisplayName>
    <Description xml:space="preserve">Read your Terraform plans like code reviews — module tree, attribute-level diffs, and replace reasons, right in your Azure DevOps build summary.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>terraform,tofu,opentofu,iac,infrastructure-as-code,plan,diff,azure-pipelines,build-tab,azurerm,devops</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/WayneGoosen/azdo-tf-plan-viewer"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/WayneGoosen/azdo-tf-plan-viewer/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/WayneGoosen/azdo-tf-plan-viewer/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/WayneGoosen/azdo-tf-plan-viewer/blob/main/LICENSE"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/WayneGoosen/azdo-tf-plan-viewer"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/tab/tab.css" d:Source="File" Path="dist/tab/tab.css" Addressable="true"/>
    <Asset Type="dist/tab/tab.html" d:Source="File" Path="dist/tab/tab.html" Addressable="true"/>
    <Asset Type="dist/tab/tab.js" d:Source="File" Path="dist/tab/tab.js" Addressable="true"/>
    <Asset Type="dist/tab/tab.js.map" d:Source="File" Path="dist/tab/tab.js.map" Addressable="true"/>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="images/extension-icon.png.txt" d:Source="File" Path="images/extension-icon.png.txt" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>