    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="dist/SprintRetro128Icon.png" Addressable="true"/>
    <Asset Type="images/.gitkeep" d:Source="File" Path="images/.gitkeep" Addressable="true"/>
    <Asset Type="images/addkudo.gif" d:Source="File" Path="images/addkudo.gif" Addressable="true"/>
