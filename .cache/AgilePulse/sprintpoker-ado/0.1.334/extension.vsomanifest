{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "sprintpoker-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "SprintPoker",
                "uri": "dist/index.html",
                "supportsMobile": false
            }
        },
        {
            "id": "sprintpoker-quick-estimation",
            "type": "ms.vss-work-web.work-item-form-group",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Planning Poker",
                "uri": "dist/quick-estimation.html",
                "height": 480
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write",
        "vso.project"
    ],
    "contributionTypes": []
}