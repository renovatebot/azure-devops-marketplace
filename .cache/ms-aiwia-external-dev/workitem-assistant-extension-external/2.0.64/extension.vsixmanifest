      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://go.microsoft.com/fwlink/?linkid=2317610"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://go.microsoft.com/fwlink/?linkid=2317613"/>
    </Properties>
    <GalleryFlags/>
    <Icon>static/logos/logo.png</Icon>
    <License>assets/LICENSE.md</License>
  </Metadata>
