<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="universal-ai-pr-reviewer" Version="1.1.2" Publisher="AhsanKhanDGE"/>
    <DisplayName>Universal AI PR Reviewer</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">AI-powered pull request reviewer and dashboard for Azure DevOps. Review PRs using any AI model (OpenAI, Azure OpenAI, Foundry, Claude, DeepSeek, vLLM). Includes a unified cross-project PR dashboard.</Description>
    <Categories>Azure Pipelines,Azure Repos</Categories>
    <Tags>AI,Code Review,Pull Request,PR Review,Dashboard,OpenAI,Azure OpenAI,Claude,Anthropic,DeepSeek,LLM,GPT,Automated Review</Tags>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
