<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="sre-agent-analysis" Version="1.0.24" Publisher="kabalas"/>
    <DisplayName>SRE Agent Analysis</DisplayName>
    <Description xml:space="preserve">Adds an SRE Agent Analysis tab to Azure DevOps build results, showing inline root cause analysis and remediation for pipeline failures.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>SRE,SRE Agent,pipeline analysis,build failure,root cause</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/bcarthic/sre-agent-ado-pipeline"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/bcarthic/sre-agent-ado-pipeline/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/bcarthic/sre-agent-ado-pipeline/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/bcarthic/sre-agent-ado-pipeline/blob/main/PRIVACY.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://github.com/bcarthic/sre-agent-ado-pipeline/blob/main/LICENSE"/>
    </Properties>
    <Icon>static/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/settings.html" d:Source="File" Path="dist/settings.html" Addressable="true"/>
    <Asset Type="dist/settings.js" d:Source="File" Path="dist/settings.js" Addressable="true"/>
    <Asset Type="dist/sre-agent-tab.html" d:Source="File" Path="dist/sre-agent-tab.html" Addressable="true"/>
    <Asset Type="dist/sre-agent-tab.js" d:Source="File" Path="dist/sre-agent-tab.js" Addressable="true"/>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>