<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="sre-agent-analysis" Version="1.0.19" Publisher="kabalas"/>
    <DisplayName>SRE Agent Analysis</DisplayName>
    <Description xml:space="preserve">Surfaces SRE Agent diagnosis links in pipeline build results when a sreagent_{threadId} tag is present.</Description>
    <GalleryFlags/>
    <Categories>Azure Pipelines</Categories>
    <Icon>static/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/auth-end.html" d:Source="File" Path="dist/auth-end.html" Addressable="true"/>
    <Asset Type="dist/settings.html" d:Source="File" Path="dist/settings.html" Addressable="true"/>
    <Asset Type="dist/settings.js" d:Source="File" Path="dist/settings.js" Addressable="true"/>
    <Asset Type="dist/sre-agent-tab.html" d:Source="File" Path="dist/sre-agent-tab.html" Addressable="true"/>
    <Asset Type="dist/sre-agent-tab.js" d:Source="File" Path="dist/sre-agent-tab.js" Addressable="true"/>
    <Asset Type="dist/sre-agent-tab.js.LICENSE.txt" d:Source="File" Path="dist/sre-agent-tab.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>