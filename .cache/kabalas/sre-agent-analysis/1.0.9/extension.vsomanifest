{
    "manifestVersion": 1,
    "scopes": [
        "vso.build"
    ],
    "contributions": [
        {
            "id": "sre-agent-build-results-tab",
            "type": "ms.vss-build-web.build-results-tab",
            "description": "A tab contributing to build results view",
            "targets": [
                "ms.vss-build-web.build-results-view"
            ],
            "properties": {
                "name": "SRE Agent Analysis",
                "uri": "dist/sre-agent-tab.html"
            }
        },
        {
            "id": "sre-agent-settings-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "name": "SRE Agent",
                "uri": "dist/settings.html",
                "icon": "static/icon.png"
            }
        }
    ],
    "contributionTypes": []
}