{
    "manifestVersion": 1,
    "scopes": [
        "vso.build"
    ],
    "contributions": [
        {
            "id": "sre-agent-build-results-tab",
            "type": "ms.vss-build-web.build-results-tab",
            "description": "A tab contributing to build results view",
            "targets": [
                "ms.vss-build-web.build-results-view"
            ],
            "properties": {
                "name": "SRE Agent Analysis",
                "uri": "dist/sre-agent-tab.html"
            },
            "constraints": [
                {
                    "name": "Feature",
                    "properties": {
                        "featureId": "kabalas.sre-agent-analysis.sre-agent-preview"
                    }
                }
            ]
        },
        {
            "id": "sre-agent-preview",
            "type": "ms.vss-web.feature",
            "description": "Enables the SRE Agent Analysis tab on build results. Each user opts in for themselves via the Preview features panel.",
            "targets": [
                "ms.vss-web.managed-features",
                "ms.vss-web.managed-features-onprem"
            ],
            "properties": {
                "name": "SRE Agent Analysis (Preview)",
                "description": "Show the SRE Agent Analysis tab on build results pages.",
                "userConfigurable": true,
                "hostConfigurable": false
            }
        },
        {
            "id": "sre-agent-settings-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "name": "SRE Agent",
                "uri": "dist/settings.html",
                "icon": "static/icon.png"
            }
        }
    ],
    "contributionTypes": []
}