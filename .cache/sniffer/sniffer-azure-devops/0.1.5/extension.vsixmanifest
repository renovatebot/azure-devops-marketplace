<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="sniffer-azure-devops" Publisher="sniffer" Version="0.1.5"/>
    <DisplayName>Sniffer for Azure DevOps</DisplayName>
    <Description xml:space="preserve">Capture, diagnose, and fix bugs automatically. Sniffer auto-records bug context — video, console, network, and user actions — and links it to your Azure DevOps work items.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>bug tracking,session replay,ai,code review,root cause analysis</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://app.snifferweb.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://support.sniffer.dev"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://support.sniffer.dev"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.snifferweb.com/privacy-policy"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#141b4f"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="static/dialog.html" d:Source="File" Path="static/dialog.html" Addressable="true"/>
