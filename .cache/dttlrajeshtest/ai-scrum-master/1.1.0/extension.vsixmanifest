<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ai-scrum-master" Version="1.1.0" Publisher="dttlrajeshtest"/>
    <DisplayName>AI Scrum Master</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Daily Scrum submission for team members and Delivery Metrics for Scrum Masters, integrated with Azure Boards.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>scrum,standup,delivery metrics,agile</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>images/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="static/delivery-metrics.html" d:Source="File" Path="static/delivery-metrics.html" Addressable="true"/>
    <Asset Type="static/main-hub.css" d:Source="File" Path="static/main-hub.css" Addressable="true"/>
    <Asset Type="static/main-hub.html" d:Source="File" Path="static/main-hub.html" Addressable="true"/>
    <Asset Type="static/main-hub.js" d:Source="File" Path="static/main-hub.js" Addressable="true"/>
    <Asset Type="static/main-hub.js.LICENSE.txt" d:Source="File" Path="static/main-hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/metrics-hub.css" d:Source="File" Path="static/metrics-hub.css" Addressable="true"/>
    <Asset Type="static/metrics-hub.js" d:Source="File" Path="static/metrics-hub.js" Addressable="true"/>
    <Asset Type="static/metrics-hub.js.LICENSE.txt" d:Source="File" Path="static/metrics-hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/scrum-hub.css" d:Source="File" Path="static/scrum-hub.css" Addressable="true"/>
    <Asset Type="static/scrum-hub.js" d:Source="File" Path="static/scrum-hub.js" Addressable="true"/>
    <Asset Type="static/scrum-hub.js.LICENSE.txt" d:Source="File" Path="static/scrum-hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="static/scrum.html" d:Source="File" Path="static/scrum.html" Addressable="true"/>
    <Asset Type="images/logo.png" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>