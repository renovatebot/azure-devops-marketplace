<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="pr-review" Version="0.1.15" Publisher="AISRE"/>
    <DisplayName>AI PR Review + Rule Learning</DisplayName>
    <Description xml:space="preserve">AI-powered pull request review that learns from your team's own review standards. Extracts coding conventions from resolved PR comments and auto-reviews new PRs using your Azure OpenAI.</Description>
    <GalleryFlags/>
    <Categories>Azure Repos,Azure Pipelines</Categories>
    <Tags>AI,code-review,pull-request,azure-openai,security,quality,productivity</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://github.com/aisre-labs/pr-review"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/aisre-labs/pr-review"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/aisre-labs/pr-review/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://aisre-labs.github.io/pr-review/privacy"/>
    </Properties>
    <Icon>images/logo.png</Icon>
    <License>LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/hub/hub.html" d:Source="File" Path="dist/hub/hub.html" Addressable="true"/>
    <Asset Type="dist/hub/hub.js" d:Source="File" Path="dist/hub/hub.js" Addressable="true"/>
    <Asset Type="dist/pr-tab/pr-tab.html" d:Source="File" Path="dist/pr-tab/pr-tab.html" Addressable="true"/>
    <Asset Type="dist/pr-tab/pr-tab.js" d:Source="File" Path="dist/pr-tab/pr-tab.js" Addressable="true"/>
    <Asset Type="images/logo-large.png" d:Source="File" Path="images/logo-large.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Large" d:Source="File" Path="images/logo-large.png" Addressable="true"/>
    <Asset Type="images/logo.png" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>