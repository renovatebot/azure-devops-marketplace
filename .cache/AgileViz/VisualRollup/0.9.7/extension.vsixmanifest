<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="VisualRollup" Publisher="AgileViz" Version="0.9.7"/>
    <GalleryFlags>Public</GalleryFlags>
    <DisplayName>Visual Rollup</DisplayName>
    <Description xml:space="preserve">Parent work-item progress, rolled up from children's states — driven by any shared query.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>dashboard,widget,agile,scrum,visual,progress,work item,hierarchy,states,query,rollup</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/agileviz/visual-rollup"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://agileviz.com/plugins/visual-rollup/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Repository" Value="https://github.com/agileviz/visual-rollup"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/agileviz/visual-rollup/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://agileviz.com/privacy/"/>
    </Properties>
    <Icon>static/icon.png</Icon>
    <License>LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services.Cloud"/>
  </Installation>
  <Assets>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="static/visual-rollup-dark.png" d:Source="File" Path="static/visual-rollup-dark.png" Addressable="true"/>
    <Asset Type="static/visual-rollup.png" d:Source="File" Path="static/visual-rollup.png" Addressable="true"/>
    <Asset Type="dist/Config/Config.html" d:Source="File" Path="dist/Config/Config.html" Addressable="true"/>
    <Asset Type="dist/Config/Config.js" d:Source="File" Path="dist/Config/Config.js" Addressable="true"/>
    <Asset Type="dist/Widget/Widget.html" d:Source="File" Path="dist/Widget/Widget.html" Addressable="true"/>
    <Asset Type="dist/Widget/Widget.js" d:Source="File" Path="dist/Widget/Widget.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>