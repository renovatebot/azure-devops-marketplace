  <Metadata>
    <Identity Language="en-US" Id="adopilot-pr-review" Version="1.0.244" Publisher="adopilot"/>
    <DisplayName>ADO Pilot - AI PR Review</DisplayName>
    <Description xml:space="preserve">AI-powered pull request reviews for Azure DevOps. Get instant, context-aware code review feedback on every PR.</Description>
    <GalleryFlags>Paid Public</GalleryFlags>
    <Categories>Azure Repos,Azure Pipelines</Categories>
    <Tags>Paid,__BYOLENFORCED,AI code review,code review,pull request review,PR review,automated code review,AI,Azure DevOps AI,Claude</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#1a1a2e"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://adopilot.dev/extension-installed?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=getstarted"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://adopilot.dev/getting-started?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=learn"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://app.adopilot.dev/support?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://adopilot.dev/privacy?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=privacypolicy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://adopilot.dev/terms?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=license"/>
      <Property Id="Microsoft.VisualStudio.Services.EnableMarketplaceQnA" Value="true"/>
      <Property Id="Microsoft.VisualStudio.Services.CustomerQnALink" Value="https://app.adopilot.dev/support?utm_source=azure_devops_marketplace&amp;utm_medium=referral&amp;utm_campaign=extension_listing&amp;utm_content=qna_support"/>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="14"/>
    </Properties>
    <Icon>static/icon-128.png</Icon>
    <License>static/license.md</License>
  </Metadata>
