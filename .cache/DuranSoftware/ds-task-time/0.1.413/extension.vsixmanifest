<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ds-task-time" Publisher="DuranSoftware" Version="0.1.413"/>
    <DisplayName>DsTaskTime</DisplayName>
    <Description xml:space="preserve">Agrega una pestaña al cuadro de diálogo de tareas e historias de usuario para anotar tiempo</Description>
    <GalleryFlags/>
    <Categories>Azure Boards</Categories>
    <Icon>dstasktime.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="vss-extension.json" d:Source="File" Path="vss-extension.json" Addressable="true"/>
    <Asset Type="dstasktime.html" d:Source="File" Path="dstasktime.html" Addressable="true"/>
    <Asset Type="build/main.js" d:Source="File" Path="build/main.js" Addressable="true"/>
    <Asset Type="build/main.js.map" d:Source="File" Path="build/main.js.map" Addressable="true"/>
    <Asset Type="dstasktime.png" d:Source="File" Path="dstasktime.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="dstasktime.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>