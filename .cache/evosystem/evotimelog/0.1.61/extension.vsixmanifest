<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="evotimelog" Publisher="evosystem" Version="0.1.61"/>
    <DisplayName>EvoTimeLog Extension</DisplayName>
    <Description xml:space="preserve">EvoTimeLog is a native timetrack, timesheet, and timetracker tool built specifically for Azure DevOps Boards. Easily track time on work items, manage team logs, and sync fields.</Description>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Homepage" Value="https://evotimelog.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://evotimelog.com/#contato"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://evotimelog.com/#install"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://evotimelog.com/license"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://evotimelog.com/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://evotimelog.com/#features"/>
    </Properties>
    <Tags>timetrack,timetracker,time tracking,timesheet,hours,track time,tempo,horas</Tags>
    <GalleryFlags>Public</GalleryFlags>
    <License>license.txt</License>
    <Icon>logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
