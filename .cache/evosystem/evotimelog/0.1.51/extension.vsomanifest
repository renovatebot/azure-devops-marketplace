{
    "manifestVersion": 1,
    "license": "license.txt",
    "scopes": [
        "vso.work_write",
        "vso.graph",
        "vso.profile"
    ],
    "contributions": [
        {
            "id": "timetracker-hub",
            "type": "ms.vss-web.hub-group",
            "description": "Menu de navegação do TimeTracker",
            "targets": [
                "ms.vss-web.project-hub-groups-collection"
            ],
            "properties": {
                "name": "TimeLog",
                "order": 100,
                "icon": "static/logo.png"
            }
        },
        {
            "id": "ContainerHub",
            "type": "ms.vss-web.hub",
            "description": "Hub Container do TimeTracker",
            "targets": [
                ".timetracker-hub"
            ],
            "properties": {
                "name": "TimeLog",
                "order": 99,
                "uri": "dist/timetracker-container-hub/timetracker-container-hub.html",
                "icon": "static/app-folder.png"
            }
        },
        {
            "id": "timetracker-form-workitem-tab",
            "type": "ms.vss-work-web.work-item-form-page",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "TimeLog",
                "uri": "dist/timetracker-form-workitem-tab/timetracker-form-workitem-tab.html",
                "registeredObjectId": "timetracker-form-workitem-tab"
            }
        }
    ],
