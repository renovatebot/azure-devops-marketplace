<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="release-brief" Version="1.63" Publisher="AB-IT"/>
    <DisplayName>Release Brief</DisplayName>
    <Description xml:space="preserve">Collect release scope from Work Items, Pull Requests, branches, and builds; review readiness flags and scope gaps; then prepare release notes and email communication in Azure DevOps.</Description>
    <GalleryFlags>Public Paid</GalleryFlags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="14"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#111111"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://www.release-brief.com/en/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://www.release-brief.com/en/pricing/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.License" Value="https://www.release-brief.com/en/license-terms/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.release-brief.com/en/privacy-policy/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://www.release-brief.com/en/support/"/>
    </Properties>
    <Categories>Azure Boards,Azure Pipelines</Categories>
    <Tags>release management,deployment readiness,release scope,work items,pull requests,release notes,__BYOLENFORCED</Tags>
    <Icon>images/logo.png</Icon>
    <License>license-terms.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
