<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="release-brief" Version="0.1.7" Publisher="AB-IT"/>
    <DisplayName>Release Brief</DisplayName>
    <Description xml:space="preserve">A lightweight extension for Azure DevOps that helps Release Managers prepare a release with a single click.</Description>
    <Categories>Azure Pipelines</Categories>
    <Icon>images/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="release-brief.html" d:Source="File" Path="release-brief.html" Addressable="true"/>
    <Asset Type="dist/.DS_Store" d:Source="File" Path="dist/.DS_Store" Addressable="true"/>
    <Asset Type="dist/AB-IT.release-brief-0.1.3.vsix" d:Source="File" Path="dist/AB-IT.release-brief-0.1.3.vsix" Addressable="true"/>
    <Asset Type="dist/AB-IT.release-brief-0.1.4.vsix" d:Source="File" Path="dist/AB-IT.release-brief-0.1.4.vsix" Addressable="true"/>
    <Asset Type="dist/AB-IT.release-brief-0.1.5.vsix" d:Source="File" Path="dist/AB-IT.release-brief-0.1.5.vsix" Addressable="true"/>
    <Asset Type="dist/AB-IT.release-brief-0.1.6.vsix" d:Source="File" Path="dist/AB-IT.release-brief-0.1.6.vsix" Addressable="true"/>
    <Asset Type="dist/bundle.js" d:Source="File" Path="dist/bundle.js" Addressable="true"/>
    <Asset Type="dist/bundle.js.LICENSE.txt" d:Source="File" Path="dist/bundle.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="images/logo.png" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>