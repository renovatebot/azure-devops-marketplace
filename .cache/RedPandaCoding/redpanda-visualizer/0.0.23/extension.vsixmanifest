<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="redpanda-visualizer" Publisher="RedPandaCoding" Version="0.0.23"/>
    <GalleryFlags>Public</GalleryFlags>
    <DisplayName>RedPanda Visualizer</DisplayName>
    <Description xml:space="preserve">Visualize graph JSON files directly in Azure DevOps Repos and Wiki</Description>
    <Categories>Azure Repos</Categories>
    <Tags>graph,visualization,architecture,diagram</Tags>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="dist/assets/GraphVisualizer.css" d:Source="File" Path="dist/assets/GraphVisualizer.css" Addressable="true"/>
    <Asset Type="dist/assets/GraphVisualizer.js" d:Source="File" Path="dist/assets/GraphVisualizer.js" Addressable="true"/>
    <Asset Type="dist/assets/WidgetHelpers.js" d:Source="File" Path="dist/assets/WidgetHelpers.js" Addressable="true"/>
    <Asset Type="dist/assets/client.js" d:Source="File" Path="dist/assets/client.js" Addressable="true"/>
    <Asset Type="dist/assets/hub.js" d:Source="File" Path="dist/assets/hub.js" Addressable="true"/>
    <Asset Type="dist/assets/widget-config.js" d:Source="File" Path="dist/assets/widget-config.js" Addressable="true"/>
    <Asset Type="dist/assets/widget.js" d:Source="File" Path="dist/assets/widget.js" Addressable="true"/>
    <Asset Type="dist/config.html" d:Source="File" Path="dist/config.html" Addressable="true"/>
    <Asset Type="dist/examples/architecture_export.graphjson" d:Source="File" Path="dist/examples/architecture_export.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/azure_integration_sample.graphjson" d:Source="File" Path="dist/examples/azure_integration_sample.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/enterprise_sample.graphjson" d:Source="File" Path="dist/examples/enterprise_sample.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/galaxy_sample.graphjson" d:Source="File" Path="dist/examples/galaxy_sample.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/infrastructure_sample.graphjson" d:Source="File" Path="dist/examples/infrastructure_sample.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/manifest.json" d:Source="File" Path="dist/examples/manifest.json" Addressable="true"/>
    <Asset Type="dist/examples/nested_sample.graphjson" d:Source="File" Path="dist/examples/nested_sample.graphjson" Addressable="true"/>
    <Asset Type="dist/examples/sample_cluster_20.graphjson" d:Source="File" Path="dist/examples/sample_cluster_20.graphjson" Addressable="true"/>
    <Asset Type="dist/hub.html" d:Source="File" Path="dist/hub.html" Addressable="true"/>
    <Asset Type="dist/widget.html" d:Source="File" Path="dist/widget.html" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>