    <DisplayName>Pull Requests Filtered</DisplayName>
    <Description xml:space="preserve">A configurable dashboard widget showing filtered pull requests across projects, with work item traceability filtering.</Description>
    <Tags>Pull Request,Filtered,Git,Code,code review</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/ommhoa/Pull-Requests-Filtered"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#dcebfc"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light"/>
    </Properties>
    <Categories>Azure Repos</Categories>
    <GalleryFlags>Public</GalleryFlags>
    <Icon>img/logo.png</Icon>
  </Metadata>
