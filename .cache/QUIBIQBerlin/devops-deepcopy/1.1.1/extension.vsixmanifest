      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#eff1f3"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light"/>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="30"/>
    </Properties>
    <DisplayName>DeepCopy</DisplayName>
    <Icon>marketplace/deepcopy_icon.png</Icon>
    <License>marketplace/license.md</License>
