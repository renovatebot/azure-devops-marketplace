  <Metadata>
    <Identity Language="en-US" Publisher="QUIBIQBerlin" Version="1.1.1" Id="devops-deepcopy"/>
    <GalleryFlags>Public Paid</GalleryFlags>
    <Description xml:space="preserve">Deep copy a work item along with all its children.</Description>
    <Categories>Azure Boards</Categories>
    <Tags>__BYOLENFORCED,Work Items,Copy,Deep Copy,Clone,Duplicate,Hierarchy,Copy Hierarchy,Hierarchy Copy,Hierarchy Clone,Bulk Copy,Bulk,Recursive Copy,Tree Copy,Structure Copy,Structured Copy,Work Item Tree,Project Management,Parent Child</Tags>
    <Properties>
