    <Identity Language="en-US" Id="devops-assist" Publisher="TheCodeCube" Version="1.0.4"/>
    <DisplayName>DevOps Assist AI</DisplayName>
    <Description xml:space="preserve">DevOps Assist brings AI to Azure DevOps with Evolve for workitem ideation and creation, Groom for refinement, Summarize for clarity, Release Manager for delivery, and Timesheets for tracking.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="connect@codecube.com"/>
    </Properties>
    <Categories>Azure Repos</Categories>
    <License>static/eula.md</License>
    <Icon>images/icons/100px/Devops_Assist_300x.png</Icon>
  </Metadata>
