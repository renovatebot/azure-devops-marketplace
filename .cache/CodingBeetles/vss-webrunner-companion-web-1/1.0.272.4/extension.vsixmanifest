<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="vss-webrunner-companion-web-1" Version="1.0.272.4" Publisher="codingbeetles"/>
    <DisplayName>WebRunner Companion</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Now everyone on the team can own quality. Capture findings, create issues, and collaborate with the team, directly from the browser.</Description>
    <Categories>Azure Test Plans</Categories>
    <Tags>manual testing,exploratory testing,adhoc testing,test execution,submit bugs,exploratory tours,feedback,bug bashes,exploratory testing tours</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Install" Value="#supportedbrowsers"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://aka.ms/xtsupport"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://aka.ms/xtgetstarted"/>
    </Properties>
    <License>content/license.md</License>
    <Icon>icons/WebRunnerCompanion.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.TeamFoundation.Server.Integration"/>
    <InstallationTarget Id="Microsoft.VisualStudio.Services.Cloud.Integration"/>
  </Installation>
  <Assets>
    <Asset Type="images/1400X560.png" d:Source="File" Path="images/1400X560.png" Addressable="true"/>
    <Asset Type="images/440X280.png" d:Source="File" Path="images/440X280.png" Addressable="true"/>
    <Asset Type="images/920X680.png" d:Source="File" Path="images/920X680.png" Addressable="true"/>
    <Asset Type="images/Chrome.png" d:Source="File" Path="images/Chrome.png" Addressable="true"/>
    <Asset Type="images/Edge.png" d:Source="File" Path="images/Edge.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="details.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="content/license.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="icons/WebRunnerCompanion.png" Addressable="true"/>
  </Assets>
</PackageManifest>