<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="smart-workitem-creator" Publisher="AnsiByteCodeLLP" Version="1.0.4"/>
    <DisplayName>Smart Work Item Creator</DisplayName>
    <Description xml:space="preserve">AI-powered work item creation for Azure DevOps. Generate Bugs, User Stories, Features, Epics and Tasks from plain text using Azure OpenAI — review, edit, and save without leaving your board.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>AI,Work Items,Azure OpenAI,Boards,Bug,User Story,Productivity,GPT</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="dark"/>
    </Properties>
    <Icon>static/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/hub.html" d:Source="File" Path="dist/hub.html" Addressable="true"/>
    <Asset Type="dist/hub.js" d:Source="File" Path="dist/hub.js" Addressable="true"/>
    <Asset Type="dist/hub.js.LICENSE.txt" d:Source="File" Path="dist/hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/hub.js.map" d:Source="File" Path="dist/hub.js.map" Addressable="true"/>
    <Asset Type="static/icon.png" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="static/icon.png" Addressable="true"/>
    <Asset Type="docs/screenshot-bug-dev-task.png" d:Source="File" Path="docs/screenshot-bug-dev-task.png" Addressable="true"/>
    <Asset Type="docs/screenshot-bug-input.png" d:Source="File" Path="docs/screenshot-bug-input.png" Addressable="true"/>
    <Asset Type="docs/screenshot-bug-modal.png" d:Source="File" Path="docs/screenshot-bug-modal.png" Addressable="true"/>
    <Asset Type="docs/screenshot-story-input.png" d:Source="File" Path="docs/screenshot-story-input.png" Addressable="true"/>
    <Asset Type="docs/screenshot-story-modal.png" d:Source="File" Path="docs/screenshot-story-modal.png" Addressable="true"/>
    <Asset Type="docs/screenshot-story-task-assignee.png" d:Source="File" Path="docs/screenshot-story-task-assignee.png" Addressable="true"/>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>