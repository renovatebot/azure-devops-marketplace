<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="timelog-extension" Publisher="Globatech" Version="1.0.20"/>
    <DisplayName>Timely</DisplayName>
    <Description xml:space="preserve">Log time on Azure Boards work items. View team reports filtered by user, team, client and date. Export to Excel with per-user, per-team and per-client summaries.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Icon>images/icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/report-hub/report-hub.css" d:Source="File" Path="dist/report-hub/report-hub.css" Addressable="true"/>
    <Asset Type="dist/report-hub/report-hub.html" d:Source="File" Path="dist/report-hub/report-hub.html" Addressable="true"/>
    <Asset Type="dist/report-hub/report-hub.js" d:Source="File" Path="dist/report-hub/report-hub.js" Addressable="true"/>
    <Asset Type="dist/report-hub/report-hub.js.LICENSE.txt" d:Source="File" Path="dist/report-hub/report-hub.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/timelog-tab/timelog-tab.css" d:Source="File" Path="dist/timelog-tab/timelog-tab.css" Addressable="true"/>
    <Asset Type="dist/timelog-tab/timelog-tab.html" d:Source="File" Path="dist/timelog-tab/timelog-tab.html" Addressable="true"/>
    <Asset Type="dist/timelog-tab/timelog-tab.js" d:Source="File" Path="dist/timelog-tab/timelog-tab.js" Addressable="true"/>
    <Asset Type="images/icon.png" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>