<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="infisical-azure-devops-task" Publisher="infisical" Version="0.0.2"/>
    <DisplayName>Infisical Secrets</DisplayName>
    <Description xml:space="preserve">Fetch secrets from Infisical and expose them as masked pipeline variables. Supports Infisical Cloud and self-hosted instances.</Description>
    <GalleryFlags>Public Preview</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>infisical,secrets,secret-management,machine-identity,vault,pipeline</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Home" Value="https://infisical.com"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://infisical.com/docs"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://infisical.com/slack"/>
    </Properties>
    <Icon>logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="logo.png" d:Source="File" Path="logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="logo.png" Addressable="true"/>
    <Asset Type="overview.md" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>