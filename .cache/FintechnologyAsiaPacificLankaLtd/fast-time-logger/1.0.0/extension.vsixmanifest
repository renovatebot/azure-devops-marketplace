  <Metadata>
    <Identity Language="en-US" Id="fast-time-logger" Publisher="FintechnologyAsiaPacificLankaLtd" Version="1.0.0"/>
    <DisplayName>Fast Time Logger</DisplayName>
    <Description xml:space="preserve">Ultra-fast time tracking for Azure DevOps work items. Start/stop/pause timers, log time manually, and sync automatically — built for instant load, not marketplace bloat.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>time tracking,timer,work items,productivity,logging</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#0078d4"/>
      <Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light"/>
    </Properties>
    <Icon>img/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
