{
    "manifestVersion": 1,
    "scopes": [
        "vso.work_write",
        "vso.graph"
    ],
    "contributions": [
        {
            "id": "sprint-planning-hub",
            "type": "ms.vss-web.hub",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "AI Sprint Planning",
                "uri": "https://devteamaiassistant.idearoost.com/extension.html",
                "icon": {
                    "light": "src/assets/IdeaRoostIcon.jpg",
                    "dark": "src/assets/IdeaRoostIcon.jpg"
                }
            }
        }
    ],
    "contributionTypes": []
}