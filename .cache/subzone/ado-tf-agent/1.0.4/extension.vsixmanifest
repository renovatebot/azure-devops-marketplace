<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ado-tf-agent" Version="1.0.4" Publisher="subzone"/>
    <DisplayName>ADO Terraform Agent</DisplayName>
    <Description xml:space="preserve">Terraform pipeline task with multi-cloud backends plus an interactive build results tab with color-coded diffs, expandable attribute changes, dependency graph, policy warnings and PR comments.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>Terraform,IaC,Plan,Visualization,Azure,AWS,GCP,Infrastructure,DevOps</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/subzone/ado-tf-agent#readme"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/subzone/ado-tf-agent/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/subzone/ado-tf-agent/blob/main/PRIVACY.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://github.com/subzone/ado-tf-agent/blob/main/overview.md"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/subzone/ado-tf-agent"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
    <License>PRIVACY.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
