<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ado-tf-agent" Version="0.1.19" Publisher="subzone"/>
    <DisplayName>ADO Terraform Agent</DisplayName>
    <Description xml:space="preserve">Terraform pipeline task (install, init, validate, plan, apply) with Azure/AWS/GCP remote state options, plus a build results tab for plan JSON and an architecture-style diagram.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Pipelines</Categories>
    <Tags>Terraform,IaC,Plan,Azure,AWS,GCP</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/subzone/ado-tf-agent"/>
    </Properties>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
