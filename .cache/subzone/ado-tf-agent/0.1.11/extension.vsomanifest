{
    "manifestVersion": 1,
    "scopes": [
        "vso.build",
        "vso.build_execute"
    ],
    "repository": {
        "type": "git",
        "uri": "https://github.com/subzone/ado-tf-agent"
    },
    "contributions": [
        {
            "id": "terraform-task",
            "type": "ms.vss-distributed-task.task",
            "targets": [
                "ms.vss-distributed-task.tasks"
            ],
            "properties": {
                "name": "tasks/Terraform"
            }
        },
        {
            "id": "terraform-plan-tab",
            "type": "ms.vss-build-web.build-results-tab",
            "description": "Visual Terraform plan and diagram from published plan.json artifact.",
            "targets": [
                "ms.vss-build-web.build-results-view"
            ],
            "properties": {
                "name": "Terraform",
                "uri": "ui/dist/planTab.html",
                "supportsTasks": [
                    "b8f3a2c1-7d4e-4a9b-8f1c-3e5d7a9b2c4d"
                ]
            }
        }
    ],
    "contributionTypes": []
}