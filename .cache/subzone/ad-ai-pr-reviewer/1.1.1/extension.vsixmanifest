<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ad-ai-pr-reviewer" Version="1.1.1" Publisher="subzone"/>
    <DisplayName>AI PR Reviewer</DisplayName>
    <GalleryFlags>Public</GalleryFlags>
    <Description xml:space="preserve">Create pull requests and post AI-generated review comments on GitHub, GitLab, and Bitbucket from Azure DevOps pipelines.</Description>
    <Categories>Azure Pipelines</Categories>
    <Tags>pull request,AI,code review,GitHub,GitLab,Bitbucket,Claude</Tags>
    <Icon>images/extension-icon.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="images/extension-icon.png" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="images/extension-icon.png" Addressable="true"/>
    <Asset Type="images/screenshot-bestpractice-inline.png" d:Source="File" Path="images/screenshot-bestpractice-inline.png" Addressable="true"/>
    <Asset Type="images/screenshot-bug-inline.png" d:Source="File" Path="images/screenshot-bug-inline.png" Addressable="true"/>
    <Asset Type="images/screenshot-medium-inline.png" d:Source="File" Path="images/screenshot-medium-inline.png" Addressable="true"/>
    <Asset Type="images/screenshot-security-inline.png" d:Source="File" Path="images/screenshot-security-inline.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>