<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="azdo-checklist-extension" Publisher="FJANIT" Version="1.4.7"/>
    <DisplayName>Azure DevOps Checklist Extension</DisplayName>
    <Description xml:space="preserve">A comprehensive checklist template management extension for Azure DevOps work items with progress tracking and task organization</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>checklist,templates,task management,productivity,boards,work items,Check List,Form,Group,Page,Tab,multiple checklists,work item form,template management,progress tracking,workflow automation,queries,reporting,definition of done,process compliance,field mapping</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://docs.checklist.fjan.nl/docs/setup/setting-up-checklists-for-work-items"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.fjan.nl/azdo-checklist/privacy-policy"/>
    </Properties>
    <Icon>logo.png</Icon>
    <License>eula.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="dist/template-management/template-management.html" d:Source="File" Path="dist/template-management/template-management.html" Addressable="true"/>
    <Asset Type="dist/template-management/template-management.js" d:Source="File" Path="dist/template-management/template-management.js" Addressable="true"/>
    <Asset Type="dist/template-management/template-management.js.LICENSE.txt" d:Source="File" Path="dist/template-management/template-management.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/work-item-form/work-item-form.html" d:Source="File" Path="dist/work-item-form/work-item-form.html" Addressable="true"/>
    <Asset Type="dist/work-item-form/work-item-form.js" d:Source="File" Path="dist/work-item-form/work-item-form.js" Addressable="true"/>
    <Asset Type="dist/work-item-form/work-item-form.js.LICENSE.txt" d:Source="File" Path="dist/work-item-form/work-item-form.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="eula.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>