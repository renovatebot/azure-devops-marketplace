{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "time-tracker-panel",
            "type": "ms.vss-work-web.work-item-form-group",
            "description": "Time tracking control for task work items",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Time Tracking",
                "uri": "dist/time-tracker-panel.html",
                "height": 64,
                "inputs": [
                    {
                        "id": "WorkItemType",
                        "description": "Work item type",
                        "type": "WorkItemType",
                        "properties": {
                            "WorkItemTypeRefNames": [
                                "Microsoft.VSTS.WorkItemTypes.Task"
                            ]
                        }
                    }
                ]
            }
        },
        {
            "id": "qiyasly-activation-settings",
            "type": "ms.vss-web.hub",
            "description": "Configure Qiyasly extension activation",
            "targets": [
                "ms.vss-web.collection-admin-hub-group"
            ],
            "properties": {
                "name": "Qiyasly activation",
                "order": 99,
                "uri": "dist/activation-settings.html"
            }
        },
        {
            "id": "qiyasly-work-item-action",
            "type": "ms.vss-web.action-provider",
            "description": "Start or stop timer tracking from the active work item",
            "targets": [
                "ms.vss-work-web.work-item-toolbar-menu",
                "ms.vss-work-web.work-item-context-menu"
            ],
            "properties": {
                "uri": "dist/work-item-action.html",
                "registeredObjectId": "qiyasly-work-item-action"
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write",
        "vso.project"
    ],
    "contributionTypes": []
}