{
    "manifestVersion": 1,
    "scopes": [
        "vso.work",
        "vso.work_write"
    ],
    "contributions": [
        {
            "id": "testing-hub-group",
            "type": "ms.vss-web.hub-group",
            "description": "Adds a 'Testing' hub group at the project/team-level",
            "targets": [
                "ms.vss-web.project-hub-groups-collection"
            ],
            "properties": {
                "name": "Test Hub",
                "order": 100,
                "icon": {
                    "light": "dist/images/mainLogo.png",
                    "dark": "dist/images/mainLogo.png"
                }
            }
        },
        {
            "id": "test-collections",
            "type": "ms.vss-web.hub",
            "description": "Adds a 'Test Collections' hub to the Work hub group.",
            "targets": [
                ".testing-hub-group"
            ],
            "properties": {
                "name": "Test collections",
                "order": 1,
                "uri": "dist/index.html",
                "icon": {
                    "light": "dist/images/testCollectionsIconLight.png",
                    "dark": "dist/images/testCollectionsIconDark.png"
                }
            }
        },
        {
            "id": "test-runs",
            "type": "ms.vss-web.hub",
            "description": "Adds a 'Test Runs' hub to the Work hub group.",
            "targets": [
                ".testing-hub-group"
            ],
            "properties": {
                "name": "Test runs",
                "order": 2,
                "uri": "dist/index.html",
                "icon": {
                    "light": "dist/images/testRunsIconLight.png",
                    "dark": "dist/images/testRunsIconDark.png"
                }
            }
        },
        {
            "id": "steps-control",
            "type": "ms.vss-work-web.work-item-form-control",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "StepsControl",
                "uri": "dist/index.html"
            }
        },
        {
            "id": "test-cases-work-item-page",
            "type": "ms.vss-work-web.work-item-form-page",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "properties": {
                "name": "Tests",
                "uri": "dist/index.html"
            }
        },
        {
            "id": "settings-hub",
            "type": "ms.vss-web.hub",
            "description": "Settings page",
            "targets": [
                "ms.vss-web.project-admin-hub-group"
            ],
            "properties": {
                "name": "Test Hub",
                "uri": "dist/index.html"
            }
        }
    ],
    "licensing": {
        "overrides": [
            {
                "id": "testing-hub-group",
                "behavior": "AlwaysInclude"
            },
            {
                "id": "test-collections",
                "behavior": "AlwaysInclude"
            },
            {
                "id": "test-runs",
                "behavior": "AlwaysInclude"
            },
            {
                "id": "steps-control",
                "behavior": "AlwaysInclude"
            },
            {
                "id": "test-cases-work-item-page",
                "behavior": "AlwaysInclude"
            },
            {
                "id": "settings-hub",
                "behavior": "AlwaysInclude"
            }
        ]
    },
    "contributionTypes": []
}