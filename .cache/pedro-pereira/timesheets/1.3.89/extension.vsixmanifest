<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="timesheets" Version="1.3.89" Publisher="pedro-pereira"/>
    <DisplayName>🚧Time Sheets Extension🚧</DisplayName>
    <Description xml:space="preserve">A time sheet Extenton for time tiking related to work items 
 (🚧Under Development, for testing purposes only🚧)</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Icon>images/logo.png</Icon>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="README.md" d:Source="File" Path="README.md" Addressable="true"/>
