    <Asset Type="sdk/scripts/require.js" d:Source="File" Path="sdk/scripts/require.js" Addressable="true"/>
    <Asset Type="sdk/scripts/SDK-standalone.js" d:Source="File" Path="sdk/scripts/SDK-standalone.js" Addressable="true"/>
    <Asset Type="sdk/scripts/tslib.js" d:Source="File" Path="sdk/scripts/tslib.js" Addressable="true"/>
