    <Asset Type="src/services/DataService.js" d:Source="File" Path="src/services/DataService.js" Addressable="true"/>
    <Asset Type="src/services/WorkItemService.js" d:Source="File" Path="src/services/WorkItemService.js" Addressable="true"/>
    <Asset Type="src/utils/TimesheetUtils.js" d:Source="File" Path="src/utils/TimesheetUtils.js" Addressable="true"/>
    <Asset Type="src/views/timesheet.html" d:Source="File" Path="src/views/timesheet.html" Addressable="true"/>
