{
    "manifestVersion": 1,
    "contributions": [
        {
            "id": "PedroPereira.TimeSheets",
            "type": "ms.vss-web.hub",
            "description": "Adds a TimeSheets hub pannel to the Boards Tab",
            "targets": [
                "ms.vss-work-web.work-hub-group"
            ],
            "properties": {
                "name": "Time Sheets",
                "order": 99,
                "uri": "src/views/timesheet.html"
            }
        },
        {
            "id": "PedroPereira.TimeSheets.WorkItem.Group",
            "type": "ms.vss-work-web.work-item-form-group",
            "description": "Timesheets group inside Work Item form",
            "targets": [
                "ms.vss-work-web.work-item-form"
            ],
            "demands": [
                "contribution/ms.vss-web.contribution-type/ms.vss-work-web.work-item-form-group"
            ],
            "properties": {
                "name": "Timesheets",
                "uri": "src/views/workitem-timesheet-group.html",
                "height": 52,
                "order": 2
            }
        }
    ],
    "scopes": [
        "vso.work",
        "vso.work_write",
        "vso.settings_write"
    ],
    "contributionTypes": []
}