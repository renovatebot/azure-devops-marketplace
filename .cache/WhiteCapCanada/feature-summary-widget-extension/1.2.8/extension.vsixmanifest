<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="feature-summary-widget-extension" Version="1.2.8" Publisher="WhitecapCanada"/>
    <GalleryFlags>Public</GalleryFlags>
    <Tags>azure devops,azure boards,dashboard widget,feature summary,feature tracking,agile reporting,delivery tracking,work item reporting,team dashboard,project visibility</Tags>
    <DisplayName>Feature Summary Widget</DisplayName>
    <Description xml:space="preserve">Show the summary of features</Description>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://www.whitecap.com/privacy-policy/"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://www.whitecap.com/contact-us/"/>
    </Properties>
    <Icon>img/logo-128.png</Icon>
    <License>eula.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="feature-summary.html" d:Source="File" Path="feature-summary.html" Addressable="true"/>
    <Asset Type="feature-summary.js" d:Source="File" Path="feature-summary.js" Addressable="true"/>
    <Asset Type="trace-utils.js" d:Source="File" Path="trace-utils.js" Addressable="true"/>
    <Asset Type="sdk/scripts/VSS.SDK.min.js" d:Source="File" Path="sdk/scripts/VSS.SDK.min.js" Addressable="true"/>
    <Asset Type="img/CatalogIcon.png" d:Source="File" Path="img/CatalogIcon.png" Addressable="true"/>
    <Asset Type="img/logo-128.png" d:Source="File" Path="img/logo-128.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="img/logo-128.png" Addressable="true"/>
    <Asset Type="img/logo.png" d:Source="File" Path="img/logo.png" Addressable="true"/>
    <Asset Type="img/preview.png" d:Source="File" Path="img/preview.png" Addressable="true"/>
    <Asset Type="Screenshots/Screenshot1.png" d:Source="File" Path="Screenshots/Screenshot1.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.1" d:Source="File" Path="Screenshots/Screenshot1.png" Addressable="true"/>
    <Asset Type="Screenshots/Screenshot2.png" d:Source="File" Path="Screenshots/Screenshot2.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.2" d:Source="File" Path="Screenshots/Screenshot2.png" Addressable="true"/>
    <Asset Type="Screenshots/Screenshot3.png" d:Source="File" Path="Screenshots/Screenshot3.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.3" d:Source="File" Path="Screenshots/Screenshot3.png" Addressable="true"/>
    <Asset Type="Screenshots/Screenshot4.png" d:Source="File" Path="Screenshots/Screenshot4.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.4" d:Source="File" Path="Screenshots/Screenshot4.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Screenshots.5" d:Source="File" Path="Screenshots/Screenshot4.png" Addressable="true"/>
    <Asset Type="Screenshots/Screenshot5.png" d:Source="File" Path="Screenshots/Screenshot5.png" Addressable="true"/>
    <Asset Type="configuration.html" d:Source="File" Path="configuration.html" Addressable="true"/>
    <Asset Type="configuration.js" d:Source="File" Path="configuration.js" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="eula.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>