<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="git-repository-list" Publisher="CrazySolutions" Version="1.1.0"/>
    <DisplayName>Git repository list</DisplayName>
    <Description xml:space="preserve">Lists git repositories in a more convenient way</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Repos</Categories>
    <Tags>git,repos</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/CrazySolutions/AzDoExtensionGitList"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/CrazySolutions/AzDoExtensionGitList/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Issues" Value="https://github.com/CrazySolutions/AzDoExtensionGitList/issues"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://github.com/CrazySolutions/AzDoExtensionGitList/blob/master/PRIVACY.md"/>
    </Properties>
    <Icon>logo.png</Icon>
    <License>LICENSE</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services"/>
  </Installation>
  <Assets>
    <Asset Type="static/git-icon-128.png" d:Source="File" Path="static/git-icon-128.png" Addressable="true"/>
    <Asset Type="static/overview_collection.PNG" d:Source="File" Path="static/overview_collection.PNG" Addressable="true"/>
    <Asset Type="static/overview_repos.PNG" d:Source="File" Path="static/overview_repos.PNG" Addressable="true"/>
    <Asset Type="dist/4111627f66c0b5e39d5b.woff2" d:Source="File" Path="dist/4111627f66c0b5e39d5b.woff2" Addressable="true"/>
    <Asset Type="dist/5fbecc534e14189d1e12.woff2" d:Source="File" Path="dist/5fbecc534e14189d1e12.woff2" Addressable="true"/>
    <Asset Type="dist/org-hub/index.html" d:Source="File" Path="dist/org-hub/index.html" Addressable="true"/>
    <Asset Type="dist/org-hub/index.js" d:Source="File" Path="dist/org-hub/index.js" Addressable="true"/>
    <Asset Type="dist/org-hub/index.js.LICENSE.txt" d:Source="File" Path="dist/org-hub/index.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="dist/repos-hub/index.html" d:Source="File" Path="dist/repos-hub/index.html" Addressable="true"/>
    <Asset Type="dist/repos-hub/index.js" d:Source="File" Path="dist/repos-hub/index.js" Addressable="true"/>
    <Asset Type="dist/repos-hub/index.js.LICENSE.txt" d:Source="File" Path="dist/repos-hub/index.js.LICENSE.txt" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="logo.png" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.Details" d:Source="File" Path="overview.md" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Content.License" d:Source="File" Path="LICENSE" Addressable="true"/>
    <Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true"/>
  </Assets>
</PackageManifest>