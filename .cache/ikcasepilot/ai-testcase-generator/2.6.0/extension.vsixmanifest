<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="ai-testcase-generator" Publisher="ikcasepilot" Version="2.6.0"/>
    <DisplayName>CasePilot - AI Test Case Generator</DisplayName>
    <Description xml:space="preserve">Generate structured, automation-ready test cases from User Stories using a two-pass AI Worker + Judge pipeline. Free tier included.</Description>
    <GalleryFlags>Public</GalleryFlags>
    <Categories>Azure Boards</Categories>
    <Tags>test cases,AI,testing,QA,test generation,automation,user stories</Tags>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://api.iklab.dev/api/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="mailto:ihor.kosheliev23@gmail.com"/>
    </Properties>
    <Icon>images/icon.png</Icon>
  </Metadata>
