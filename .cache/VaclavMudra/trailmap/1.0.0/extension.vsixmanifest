<?xml version="1.0" encoding="utf-8"?>
<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
  <Metadata>
    <Identity Language="en-US" Id="trailmap" Publisher="VaclavMudra" Version="1.0.0"/>
    <DisplayName>Trailmap — Roadmaps for Azure Boards</DisplayName>
    <Description xml:space="preserve">Epic-centric, exportable roadmap over Azure Boards. The view Delivery Plans can't draw: features nested under epics, dates computed from child work items, PNG export for slides.</Description>
    <Categories>Azure Boards</Categories>
    <Properties>
      <Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://trailmap.fyi/support"/>
      <Property Id="Microsoft.VisualStudio.Services.Links.Privacypolicy" Value="https://trailmap.fyi/privacy"/>
      <Property Id="Microsoft.VisualStudio.Services.GalleryProperties.TrialDays" Value="30"/>
    </Properties>
    <GalleryFlags>Public Paid Preview</GalleryFlags>
    <Tags>__BYOLENFORCED,roadmap,timeline,gantt,epic,feature timeline,delivery plans</Tags>
    <Icon>manifest/static/icon-128.png</Icon>
    <License>docs/legal/eula.md</License>
  </Metadata>
  <Dependencies/>
  <Installation>
    <InstallationTarget Id="Microsoft.VisualStudio.Services.Cloud"/>
  </Installation>
