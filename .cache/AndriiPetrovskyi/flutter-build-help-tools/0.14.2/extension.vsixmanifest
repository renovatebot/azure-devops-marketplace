<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011"><Metadata><Identity Language="en-US" Id="flutter-build-help-tools" Version="0.14.2" Publisher="AndriiPetrovskyi" /><DisplayName>Flutter Build Help Tools</DisplayName><Description xml:space="preserve">Help tools for flutter build and release. Using this extension can prevent using custom scripts for flutter build and release.</Description><Categories>Azure Pipelines</Categories><Icon>ext_icon.png</Icon><GalleryFlags /></Metadata><Dependencies /><Installation><InstallationTarget Id="Microsoft.VisualStudio.Services" /></Installation><Assets><Asset Type="Microsoft.VisualStudio.Services.Icons.Default" d:Source="File" Path="ext_icon.png" Addressable="true" /><Asset Type="Microsoft.VisualStudio.Services.Manifest" d:Source="File" Path="extension.vsomanifest" Addressable="true" /></Assets></PackageManifest>